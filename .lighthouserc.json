{
  "ci": {
    "collect": {
      "url": [
        "https://www.theswitchboardmarketing.com/",
        "https://www.theswitchboardmarketing.com/privacy",
        "https://www.theswitchboardmarketing.com/terms",
        "https://www.theswitchboardmarketing.com/accessibility"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "throttlingMethod": "simulate",
        "onlyCategories": ["performance", "accessibility", "best-practices", "seo"],
        "skipAudits": ["canonical", "is-crawlable"]
      }
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:performance":     ["warn",  { "minScore": 0.85 }],
        "categories:accessibility":   ["error", { "minScore": 0.95 }],
        "categories:best-practices":  ["error", { "minScore": 0.90 }],
        "categories:seo":             ["error", { "minScore": 0.95 }],

        "largest-contentful-paint":   ["warn",  { "maxNumericValue": 2500 }],
        "cumulative-layout-shift":    ["warn",  { "maxNumericValue": 0.10 }],
        "interactive":                ["warn",  { "maxNumericValue": 3500 }],
        "total-blocking-time":        ["warn",  { "maxNumericValue": 300  }],

        "csp-xss":             "off",
        "uses-http2":          "off",
        "unused-javascript":   "off",
        "unused-css-rules":    "off",
        "uses-rel-preconnect": "off",

        "is-crawlable":              "off",
        "lcp-lazy-loaded":           "off",
        "non-composited-animations": "off",
        "prioritize-lcp-image":      "off",
        "unsized-images":            "warn"
      }
    },
    "upload": { "target": "temporary-public-storage" }
  }
}
