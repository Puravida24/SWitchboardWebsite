@page
@model IndexModel
@{
    ViewData["Title"] = "Insurance Intelligence Platform";
    ViewData["MetaDescription"] = "The Switchboard enriches, scores, segments, and routes insurance opportunities in real time. Turn raw prospects into revenue.";
}

<!-- Hero -->
<section style="min-height: 100vh; display: flex; align-items: center; padding-top: 5rem;">
    <div class="container-site">
        <div style="max-width: 42rem;">
            <div style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.75rem; border-radius: 9999px; background: rgba(37,99,235,0.08); border: 1px solid rgba(37,99,235,0.15); color: var(--accent-blue-light); font-size: 0.75rem; font-weight: 500; margin-bottom: 1.5rem;">
                <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--accent-blue-light); animation: pulse 2s ease-in-out infinite;"></span>
                Insurance Intelligence Platform
            </div>
            <h1 style="font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em; line-height: 1.05; margin-bottom: 1.5rem;">
                Turn raw prospects<br>
                <span class="text-accent-blue">into revenue.</span>
            </h1>
            <p style="font-size: 1.125rem; color: var(--slate-400); line-height: 1.7; margin-bottom: 2rem; max-width: 32rem;">
                The only platform that enriches, scores, segments, and routes insurance opportunities in real time — so every dollar works harder.
            </p>
            <div style="display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;">
                <a asp-page="/Demo" class="btn-primary" style="padding: 0.875rem 1.75rem; border-radius: 0.5rem; font-size: 0.875rem; font-weight: 600;">
                    Book a Demo
                </a>
                <a asp-page="/Solutions/Index" class="btn-secondary" style="padding: 0.875rem 1.75rem; border-radius: 0.5rem; font-size: 0.875rem; font-weight: 600;">
                    See How It Works
                </a>
            </div>
            <div style="display: flex; align-items: center; gap: 1.5rem; margin-top: 2.5rem; font-size: 0.875rem; color: var(--slate-500);">
                <span>Trusted by 200+ agencies</span>
                <span>·</span>
                <span>$2.4B in premiums influenced</span>
            </div>
        </div>
    </div>
</section>

<!-- Stats -->
<section style="padding: 6rem 0; border-top: 1px solid rgba(30,41,59,0.5);">
    <div class="container-site" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 3rem;">
        <div class="stat-accent-border">
            <div style="font-size: 2.5rem; font-weight: 800; color: white; margin-bottom: 0.25rem;">340%</div>
            <div style="font-size: 0.875rem; color: var(--slate-500);">Average ROI</div>
        </div>
        <div class="stat-accent-border">
            <div style="font-size: 2.5rem; font-weight: 800; color: white; margin-bottom: 0.25rem;">0.3s</div>
            <div style="font-size: 0.875rem; color: var(--slate-500);">Enrichment Speed</div>
        </div>
        <div class="stat-accent-border">
            <div style="font-size: 2.5rem; font-weight: 800; color: white; margin-bottom: 0.25rem;">47%</div>
            <div style="font-size: 0.875rem; color: var(--slate-500);">Lower CPA</div>
        </div>
        <div class="stat-accent-border">
            <div style="font-size: 2.5rem; font-weight: 800; color: white; margin-bottom: 0.25rem;">12M+</div>
            <div style="font-size: 0.875rem; color: var(--slate-500);">Prospects Processed</div>
        </div>
    </div>
</section>

<!-- CTA -->
<section style="padding: 6rem 0; border-top: 1px solid rgba(30,41,59,0.5);">
    <div class="container-site" style="text-align: center; max-width: 48rem;">
        <h2 style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; letter-spacing: -0.02em; margin-bottom: 1.5rem;">
            Ready to see what<br>intelligence looks like?
        </h2>
        <p style="color: var(--slate-400); margin-bottom: 2rem;">
            Book a 15-minute demo and see how The Switchboard transforms your insurance operation.
        </p>
        <a asp-page="/Demo" class="btn-primary" style="padding: 1rem 2rem; border-radius: 0.5rem; font-size: 0.875rem; font-weight: 600;">
            Book Your Demo
        </a>
    </div>
</section>

@section Head {
    <style>
        @@keyframes pulse {
            0%, 100% { opacity: 0.5; }
            50% { opacity: 1; }
        }
    </style>
}
