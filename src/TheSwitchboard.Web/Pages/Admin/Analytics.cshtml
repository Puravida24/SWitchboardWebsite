@page
@model TheSwitchboard.Web.Pages.Admin.AnalyticsModel
@{
    ViewData["Title"] = "Analytics";
    Layout = "_AdminLayout";
}

<h1 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 1.5rem;">Analytics</h1>

<div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 2rem;">
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 8px; padding: 1rem;">
        <div style="font-size: 0.68rem; color: var(--slate-400); letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 0.4rem;">Today</div>
        <div style="font-size: 1.8rem; font-weight: 700; color: white; font-variant-numeric: tabular-nums;">@Model.Today</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 8px; padding: 1rem;">
        <div style="font-size: 0.68rem; color: var(--slate-400); letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 0.4rem;">This Week</div>
        <div style="font-size: 1.8rem; font-weight: 700; color: white; font-variant-numeric: tabular-nums;">@Model.Week</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 8px; padding: 1rem;">
        <div style="font-size: 0.68rem; color: var(--slate-400); letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 0.4rem;">This Month</div>
        <div style="font-size: 1.8rem; font-weight: 700; color: white; font-variant-numeric: tabular-nums;">@Model.Month</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 8px; padding: 1rem;">
        <div style="font-size: 0.68rem; color: var(--slate-400); letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 0.4rem;">Unique Visitors · Week</div>
        <div style="font-size: 1.8rem; font-weight: 700; color: white; font-variant-numeric: tabular-nums;">@Model.UniqueVisitorsWeek</div>
    </div>
</div>

<h2 style="font-size: 1.05rem; font-weight: 600; margin-bottom: 0.75rem;">Top Pages · Last 7 Days</h2>
<table style="width: 100%; border-collapse: collapse; font-size: 0.9rem; margin-bottom: 2rem;">
    <thead>
        <tr style="text-align: left; color: var(--slate-400); border-bottom: 1px solid rgba(255,255,255,0.08);">
            <th style="padding: 0.5rem; font-weight: 500;">Path</th>
            <th style="padding: 0.5rem; font-weight: 500; text-align: right;">Views</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model.TopPages)
        {
            <tr style="border-bottom: 1px solid rgba(255,255,255,0.04); color: white;">
                <td style="padding: 0.5rem; font-family: ui-monospace, monospace;">@p.Path</td>
                <td style="padding: 0.5rem; font-variant-numeric: tabular-nums; text-align: right;">@p.Count</td>
            </tr>
        }
    </tbody>
</table>

<h2 style="font-size: 1.05rem; font-weight: 600; margin-bottom: 0.75rem;">Scroll Depth · Last 7 Days</h2>
<div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.75rem; font-size: 0.85rem;">
    @foreach (var bucket in new[] { 25, 50, 75, 100 })
    {
        var count = Model.ScrollBuckets.GetValueOrDefault(bucket, 0);
        <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 6px; padding: 0.7rem;">
            <div style="font-size: 0.68rem; color: var(--slate-400); letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 0.3rem;">@bucket%+ scroll</div>
            <div style="font-size: 1.2rem; color: white; font-variant-numeric: tabular-nums;">@count</div>
        </div>
    }
</div>
