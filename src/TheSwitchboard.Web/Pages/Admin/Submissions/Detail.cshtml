@page
@model TheSwitchboard.Web.Pages.Admin.Submissions.DetailModel
@{
    ViewData["Title"] = "Submission";
    Layout = "_AdminLayout";
}

@if (Model.Submission is null)
{
    <h1>Not found</h1>
    <p style="color: var(--slate-400);">No submission with that id.</p>
    return;
}

<div style="display: flex; align-items: baseline; gap: 1rem; margin-bottom: 1.5rem;">
    <h1 style="font-size: 1.5rem; font-weight: 700;">Submission #@Model.Submission.Id</h1>
    <span style="font-size: 0.8rem; padding: 2px 10px; border-radius: 2px; background: rgba(147,180,255,0.14); color: #93b4ff; letter-spacing: 0.14em; font-weight: 600; text-transform: uppercase;">
        @Model.Submission.PhoenixSyncStatus
    </span>
    @if (Model.Submission.BouncedEmail)
    {
        <span style="font-size: 0.8rem; padding: 2px 10px; border-radius: 2px; background: rgba(239,68,68,0.14); color: #ef4444; letter-spacing: 0.14em; font-weight: 600; text-transform: uppercase;">Bounced</span>
    }
</div>

<dl style="display: grid; grid-template-columns: 180px 1fr; gap: 0.5rem 1rem; font-size: 0.9rem; color: white; margin-bottom: 2rem;">
    <dt style="color: var(--slate-400); font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase;">Received</dt>
    <dd style="font-variant-numeric: tabular-nums;">@Model.Submission.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss 'UTC'")</dd>
    <dt style="color: var(--slate-400); font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase;">Form</dt>
    <dd>@Model.Submission.FormType</dd>
    <dt style="color: var(--slate-400); font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase;">Role</dt>
    <dd>@(Model.Submission.Role ?? "—")</dd>
    <dt style="color: var(--slate-400); font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase;">Source page</dt>
    <dd>@(Model.Submission.SourcePage ?? "—")</dd>
    <dt style="color: var(--slate-400); font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase;">IP</dt>
    <dd style="font-variant-numeric: tabular-nums;">@(Model.Submission.IpAddress ?? "—")</dd>
    <dt style="color: var(--slate-400); font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase;">User agent</dt>
    <dd style="font-family: ui-monospace, monospace; font-size: 0.8rem; word-break: break-all;">@(Model.Submission.UserAgent ?? "—")</dd>
    <dt style="color: var(--slate-400); font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase;">Phoenix attempts</dt>
    <dd>@Model.Submission.PhoenixSyncAttempts (last: @(Model.Submission.LastPhoenixAttemptAt?.ToString("yyyy-MM-dd HH:mm:ss 'UTC'") ?? "—"))</dd>
</dl>

<h2 style="font-size: 1.05rem; font-weight: 600; margin-bottom: 0.75rem;">Payload</h2>
<pre style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 6px; padding: 1rem; color: white; font-family: ui-monospace, monospace; font-size: 0.85rem; overflow-x: auto;">@Model.Submission.Data</pre>

<form method="post" action="/Admin/Phoenix/Test" style="margin-top: 2rem;">
    <button type="submit" style="background: rgba(147,180,255,0.14); color: #d4e0ff; border: 1px solid rgba(147,180,255,0.28); padding: 0.5rem 1rem; border-radius: 6px; font-family: ui-monospace, monospace; font-size: 0.78rem; letter-spacing: 0.14em; text-transform: uppercase; cursor: pointer;">Ping Phoenix (test payload)</button>
</form>
