@page
@model TheSwitchboard.Web.Pages.Admin.ComingSoonModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = Model.Feature + " — Coming soon";
}

<div style="max-width: 720px; margin: 6rem auto; text-align: center;">
  <div style="display: inline-flex; align-items: center; justify-content: center; width: 64px; height: 64px; border-radius: 999px; background: rgba(59,130,246,0.12); border: 1px solid rgba(59,130,246,0.3); margin-bottom: 1.5rem;">
    <span style="font-size: 1.75rem;">⚡</span>
  </div>

  <h1 style="font-size: 1.75rem; font-weight: 700; color: white; margin-bottom: 0.5rem;">@Model.Feature</h1>
  <div style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.15em; color: #3b82f6; margin-bottom: 1.5rem;">Coming soon</div>

  <p style="color: var(--slate-400); font-size: 1rem; line-height: 1.6; margin-bottom: 2rem;">
    This admin surface is queued up in the reporting platform build. The data pipeline
    is already capturing everything — we just haven't built the screen yet.
  </p>

  @if (!string.IsNullOrEmpty(Model.Eta))
  {
    <div style="display: inline-block; padding: 0.5rem 1rem; border-radius: 999px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); color: var(--slate-400); font-size: 0.75rem; margin-bottom: 2rem;">
      ETA: @Model.Eta
    </div>
  }

  <div style="display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap;">
    <a href="/Admin/Dashboard" style="padding: 0.625rem 1.25rem; border-radius: 0.375rem; background: rgba(59,130,246,0.2); border: 1px solid rgba(59,130,246,0.4); color: white; text-decoration: none; font-size: 0.875rem;">← Back to Dashboard</a>
    <a href="/Admin/Reports/Health" style="padding: 0.625rem 1.25rem; border-radius: 0.375rem; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); color: var(--slate-300); text-decoration: none; font-size: 0.875rem;">Tracker Health</a>
  </div>
</div>
