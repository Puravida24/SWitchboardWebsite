@{
    Layout = null;
    var path = Context.Request.Path.Value ?? string.Empty;
    bool GroupOpen(string groupId) => groupId switch
    {
        "content"  => path.StartsWith("/Admin/Partners", StringComparison.OrdinalIgnoreCase)
                   || path.StartsWith("/Admin/ComingSoon", StringComparison.OrdinalIgnoreCase),
        "forms"    => path.StartsWith("/Admin/Submissions", StringComparison.OrdinalIgnoreCase)
                   || path.StartsWith("/Admin/Reports/Forms", StringComparison.OrdinalIgnoreCase)
                   || path.StartsWith("/Admin/Reports/Abandonment", StringComparison.OrdinalIgnoreCase),
        "reports"  => path.StartsWith("/Admin/Reports", StringComparison.OrdinalIgnoreCase)
                   && !path.StartsWith("/Admin/Reports/Forms", StringComparison.OrdinalIgnoreCase)
                   && !path.StartsWith("/Admin/Reports/Abandonment", StringComparison.OrdinalIgnoreCase)
                   && !path.StartsWith("/Admin/Reports/Compliance", StringComparison.OrdinalIgnoreCase)
                   && !path.StartsWith("/Admin/Reports/Certificates", StringComparison.OrdinalIgnoreCase)
                   && !path.StartsWith("/Admin/Reports/Disclosures", StringComparison.OrdinalIgnoreCase),
        "consent"  => path.StartsWith("/Admin/Reports/Compliance", StringComparison.OrdinalIgnoreCase)
                   || path.StartsWith("/Admin/Reports/Certificates", StringComparison.OrdinalIgnoreCase)
                   || path.StartsWith("/Admin/Reports/Disclosures", StringComparison.OrdinalIgnoreCase),
        "settings" => path.StartsWith("/Admin/Settings", StringComparison.OrdinalIgnoreCase),
        _          => false
    };
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Switchboard Admin</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <meta name="robots" content="noindex, nofollow" />
    <script src="~/js/admin/cmdk.js" asp-append-version="true" defer></script>
    <script src="~/js/admin/sidebar.js" asp-append-version="true" defer></script>
    <style>
      /* A15 — inline help tooltip, admin-only. CSS-only (no JS).
         Usage:  <span class="tb-help" data-tip="Plain-English explanation">?</span>  */
      .tb-help {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1rem;
        height: 1rem;
        margin-left: 0.375rem;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        background: rgba(255, 255, 255, 0.04);
        color: var(--slate-400);
        font-size: 0.6875rem;
        font-weight: 600;
        line-height: 1;
        vertical-align: middle;
        cursor: help;
        position: relative;
      }
      .tb-help:hover, .tb-help:focus-visible {
        color: white;
        border-color: rgba(59, 130, 246, 0.6);
        background: rgba(59, 130, 246, 0.15);
        outline: none;
      }
      .tb-help::after {
        content: attr(data-tip);
        position: absolute;
        bottom: calc(100% + 0.5rem);
        left: 50%;
        transform: translateX(-50%);
        min-width: 14rem;
        max-width: 22rem;
        padding: 0.625rem 0.75rem;
        background: #0f172a;
        color: var(--slate-200);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 0.375rem;
        font-size: 0.75rem;
        font-weight: 400;
        line-height: 1.4;
        text-align: left;
        white-space: normal;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.12s ease;
        z-index: 50;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
      }
      .tb-help:hover::after, .tb-help:focus-visible::after { opacity: 1; }

      /* H-7b — collapsible sidebar groups. <details>+<summary> for accessibility;
         JS persists state per group id to localStorage. */
      .sb-group { margin-top: 1rem; }
      .sb-group > summary {
        list-style: none;
        cursor: pointer;
        user-select: none;
        padding: 0.375rem 0.75rem;
        margin-bottom: 0.375rem;
        font-size: 0.625rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--slate-600);
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-radius: 0.25rem;
      }
      .sb-group > summary::-webkit-details-marker { display: none; }
      .sb-group > summary:hover { color: var(--slate-400); background: rgba(255,255,255,0.02); }
      .sb-group > summary::after {
        content: "▸";
        font-size: 0.6875rem;
        color: var(--slate-600);
        transition: transform 0.12s ease;
      }
      .sb-group[open] > summary::after { transform: rotate(90deg); }
      .sb-group > *:not(summary) { margin-left: 0; }
    </style>
</head>
<body style="display: flex; min-height: 100vh;">
    <!-- Sidebar -->
    <aside style="width: 240px; background: rgba(255,255,255,0.02); border-right: 1px solid rgba(255,255,255,0.05); padding: 1.5rem; flex-shrink: 0;">
        <div style="font-size: 1rem; font-weight: 700; color: white; margin-bottom: 1rem;">
            <span class="text-accent-blue">⚡</span> Admin
        </div>
        <div style="font-size: 0.625rem; color: var(--slate-600); margin-bottom: 1.25rem; padding: 0.375rem 0.625rem; border: 1px dashed rgba(255,255,255,0.08); border-radius: 0.25rem; text-align: center;">
            Press <kbd style="font-family: ui-monospace, monospace; color: white;">⌘K</kbd> / <kbd style="font-family: ui-monospace, monospace; color: white;">Ctrl K</kbd> to jump anywhere
        </div>
        <nav style="display: flex; flex-direction: column; gap: 0.25rem;">
            <a href="/Admin/Dashboard" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); transition: all 0.15s;">Dashboard</a>
            <a href="/Admin/Reports/RealTime" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: white; background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.3); display: flex; align-items: center; gap: 0.375rem; margin-top: 0.25rem;">
              <span style="display: inline-block; width: 6px; height: 6px; border-radius: 999px; background: #10b981;"></span>Real-time
            </a>

            <details class="sb-group" data-group-id="content" @(GroupOpen("content") ? "open" : "")>
              <summary>Content</summary>
              <a href="/Admin/ComingSoon?feature=Blog+Posts&eta=T-9"   style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Blog Posts</a>
              <a href="/Admin/ComingSoon?feature=Case+Studies&eta=T-9" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Case Studies</a>
              <a href="/Admin/ComingSoon?feature=Testimonials&eta=T-9" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Testimonials</a>
              <a href="/Admin/ComingSoon?feature=Team&eta=T-9"         style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Team</a>
              <a href="/Admin/Partners"                                 style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Partners &amp; Logos</a>
              <a href="/Admin/ComingSoon?feature=FAQs&eta=T-9"          style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">FAQs</a>
            </details>

            <details class="sb-group" data-group-id="forms" @(GroupOpen("forms") ? "open" : "")>
              <summary>Forms</summary>
              <a href="/Admin/Submissions"                   style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Submissions</a>
              <a href="/Admin/Reports/Forms/Funnel"          style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Form Funnel</a>
              <a href="/Admin/Reports/Abandonment"           style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Abandonment</a>
            </details>

            <details class="sb-group" data-group-id="reports" @(GroupOpen("reports") ? "open" : "")>
              <summary>Reports</summary>
              <a href="/Admin/Reports/Overview"       style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Overview</a>
              <a href="/Admin/Reports/Trends"         style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Trends</a>
              <a href="/Admin/Reports/Visitors"       style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Visitors</a>
              <a href="/Admin/Reports/Cohorts"        style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Cohorts</a>
              <a href="/Admin/Reports/Engagement"     style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Engagement</a>
              <a href="/Admin/Reports/Attribution"    style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Attribution</a>
              <a href="/Admin/Reports/Sessions"       style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Sessions</a>
              <a href="/Admin/Reports/Frustration"    style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Frustration</a>
              <a href="/Admin/Reports/Heatmaps/Click" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Click heatmap</a>
              <a href="/Admin/Reports/Heatmaps/Scroll" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Scroll heatmap</a>
              <a href="/Admin/Reports/Performance"    style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Performance</a>
              <a href="/Admin/Reports/Errors"         style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">JS errors</a>
              <a href="/Admin/Reports/ErrorImpact"    style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Error impact</a>
              <a href="/Admin/Reports/UtmBuilder"     style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">UTM builder</a>
              <a href="/Admin/Reports/Goals"          style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Goals</a>
              <a href="/Admin/Reports/Insights"       style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Insights</a>
              <a href="/Admin/Reports/Alerts"         style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Alerts</a>
              <a href="/Admin/Reports/Segments"       style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Segments</a>
              <a href="/Admin/Reports/Health"         style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Health</a>
              <a href="/Admin/Reports/Deploys"        style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Deploys</a>
              <a href="/Admin/Reports/ChangesLog"     style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Changes log</a>
              <a href="/Admin/Reports/Exports"        style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Exports</a>
              <a href="/Admin/Reports/DSR"            style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">DSR</a>
            </details>

            <details class="sb-group" data-group-id="consent" @(GroupOpen("consent") ? "open" : "")>
              <summary>Consent · TCPA</summary>
              <a href="/Admin/Reports/Compliance"   style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Compliance</a>
              <a href="/Admin/Reports/Certificates" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Certificates</a>
              <a href="/Admin/Reports/Disclosures"  style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Disclosures</a>
            </details>

            <details class="sb-group" data-group-id="settings" @(GroupOpen("settings") ? "open" : "")>
              <summary>Settings</summary>
              <a href="/Admin/Settings" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); display: block;">Site Settings</a>
            </details>
        </nav>
        <div style="margin-top: auto; padding-top: 2rem;">
            <form method="post" asp-page="/Admin/Logout">
                @Html.AntiForgeryToken()
                <button type="submit" style="width: 100%; padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-500); background: none; border: 1px solid rgba(255,255,255,0.05); cursor: pointer;">
                    Sign Out
                </button>
            </form>
        </div>
    </aside>

    <!-- Main content -->
    <main style="flex: 1; padding: 2rem;">
        @RenderBody()
    </main>
</body>
</html>
