@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Switchboard Admin</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <meta name="robots" content="noindex, nofollow" />
</head>
<body style="display: flex; min-height: 100vh;">
    <!-- Sidebar -->
    <aside style="width: 240px; background: rgba(255,255,255,0.02); border-right: 1px solid rgba(255,255,255,0.05); padding: 1.5rem; flex-shrink: 0;">
        <div style="font-size: 1rem; font-weight: 700; color: white; margin-bottom: 2rem;">
            <span class="text-accent-blue">⚡</span> Admin
        </div>
        <nav style="display: flex; flex-direction: column; gap: 0.25rem;">
            <a href="/Admin/Dashboard" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400); transition: all 0.15s;">Dashboard</a>
            <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-600); margin-top: 1rem; margin-bottom: 0.5rem; padding-left: 0.75rem;">Content</div>
            <a href="/Admin/ComingSoon?feature=Blog+Posts&eta=T-9" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400);">Blog Posts</a>
            <a href="/Admin/ComingSoon?feature=Case+Studies&eta=T-9" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400);">Case Studies</a>
            <a href="/Admin/ComingSoon?feature=Testimonials&eta=T-9" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400);">Testimonials</a>
            <a href="/Admin/ComingSoon?feature=Team&eta=T-9" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400);">Team</a>
            <a href="/Admin/Partners" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400);">Partners &amp; Logos</a>
            <a href="/Admin/ComingSoon?feature=FAQs&eta=T-9" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400);">FAQs</a>
            <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-600); margin-top: 1rem; margin-bottom: 0.5rem; padding-left: 0.75rem;">Forms</div>
            <a href="/Admin/Submissions" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400);">Submissions</a>
            <a href="/Admin/Reports/Forms/Funnel" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400);">Form Funnel</a>
            <a href="/Admin/Reports/Abandonment" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400);">Abandonment</a>
            <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-600); margin-top: 1rem; margin-bottom: 0.5rem; padding-left: 0.75rem;">Reports</div>
            <a href="/Admin/Reports/Health" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400);">Health</a>
            <a href="/Admin/Reports/Attribution" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400);">Attribution</a>
            <a href="/Admin/Reports/Sessions" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400);">Sessions</a>
            <a href="/Admin/Reports/Frustration" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400);">Frustration</a>
            <a href="/Admin/Reports/Heatmaps/Click" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400);">Click heatmap</a>
            <a href="/Admin/Reports/Heatmaps/Scroll" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400);">Scroll heatmap</a>
            <a href="/Admin/Reports/Performance" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400);">Performance</a>
            <a href="/Admin/Reports/Errors" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400);">JS errors</a>
            <a href="/Admin/Reports/ErrorImpact" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400);">Error impact</a>
            <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-600); margin-top: 1rem; margin-bottom: 0.5rem; padding-left: 0.75rem;">Consent · TCPA</div>
            <a href="/Admin/Reports/Compliance" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400);">Compliance</a>
            <a href="/Admin/Reports/Certificates" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400);">Certificates</a>
            <a href="/Admin/Reports/Disclosures" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400);">Disclosures</a>
            <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-600); margin-top: 1rem; margin-bottom: 0.5rem; padding-left: 0.75rem;">Settings</div>
            <a href="/Admin/Settings" style="padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-400);">Site Settings</a>
        </nav>
        <div style="margin-top: auto; padding-top: 2rem;">
            <form method="post" asp-page="/Admin/Logout">
                @Html.AntiForgeryToken()
                <button type="submit" style="width: 100%; padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; color: var(--slate-500); background: none; border: 1px solid rgba(255,255,255,0.05); cursor: pointer;">
                    Sign Out
                </button>
            </form>
        </div>
    </aside>

    <!-- Main content -->
    <main style="flex: 1; padding: 2rem;">
        @RenderBody()
    </main>
</body>
</html>
