@page
@model TheSwitchboard.Web.Pages.Admin.MarketingPartners.IndexModel
@{
    ViewData["Title"] = "Marketing Partners";
    Layout = "_AdminLayout";
}

<h1 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 0.5rem;">Marketing Partners</h1>
<p style="color: var(--slate-400); font-size: 0.85rem; margin-bottom: 1.5rem;">
    @Model.TotalCount.ToString("N0") total · @Model.ActiveCount.ToString("N0") active · @Model.LinkedCount.ToString("N0") hyperlinked
</p>

<form method="post" asp-page-handler="Create" style="display: grid; grid-template-columns: 1fr 1fr auto; gap: 0.75rem; margin-bottom: 1.5rem; align-items: end;">
    @Html.AntiForgeryToken()
    <div>
        <label style="display: block; font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--slate-400); margin-bottom: 0.35rem;">Partner name</label>
        <input name="name" required style="width: 100%; padding: 0.5rem 0.7rem; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 6px; color: white; font-size: 0.9rem;" />
    </div>
    <div>
        <label style="display: block; font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--slate-400); margin-bottom: 0.35rem;">Website URL (optional)</label>
        <input name="websiteUrl" type="url" placeholder="https://..." style="width: 100%; padding: 0.5rem 0.7rem; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 6px; color: white; font-size: 0.9rem;" />
    </div>
    <button type="submit" style="background: #3b82f6; color: white; border: none; padding: 0.55rem 1.1rem; border-radius: 6px; font-weight: 600; cursor: pointer; font-size: 0.9rem;">Add</button>
</form>

@if (TempData["ImportResult"] is string importMsg)
{
    <div style="padding: 0.7rem 1rem; background: rgba(59,130,246,0.15); border: 1px solid rgba(59,130,246,0.35); border-radius: 6px; color: #bfdbfe; margin-bottom: 1rem; font-size: 0.85rem;">@importMsg</div>
}

<form method="post" asp-page-handler="Import" enctype="multipart/form-data" style="display: flex; gap: 0.75rem; margin-bottom: 1.25rem; align-items: end; padding: 0.75rem 1rem; background: rgba(255,255,255,0.02); border: 1px dashed rgba(255,255,255,0.1); border-radius: 6px;">
    @Html.AntiForgeryToken()
    <div style="flex:1">
        <label style="display: block; font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--slate-400); margin-bottom: 0.35rem;">Bulk CSV import</label>
        <input type="file" name="file" accept=".csv,text/csv" required style="color: white; font-size: 0.85rem;" />
        <span style="color: var(--slate-500); font-size: 0.78rem; display: block; margin-top: 0.35rem;">One column "Name", or two columns "Name,Url". Existing names (case-insensitive) are skipped.</span>
    </div>
    <button type="submit" style="background: #10b981; color: white; border: none; padding: 0.55rem 1.1rem; border-radius: 6px; font-weight: 600; cursor: pointer; font-size: 0.9rem;">Import</button>
</form>

<form method="get" style="margin-bottom: 1rem;">
    <input name="q" value="@Model.Query" placeholder="Search partners…" style="width: 320px; padding: 0.5rem 0.7rem; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 6px; color: white; font-size: 0.9rem;" />
    <button type="submit" style="background: rgba(255,255,255,0.08); color: white; border: none; padding: 0.55rem 1rem; border-radius: 6px; font-size: 0.85rem; cursor: pointer; margin-left: 0.35rem;">Search</button>
    @if (!string.IsNullOrEmpty(Model.Query))
    {
        <a href="/Admin/MarketingPartners" style="color: #93b4ff; font-size: 0.85rem; margin-left: 0.5rem;">Clear</a>
    }
</form>

<table style="width: 100%; border-collapse: collapse; font-size: 0.88rem;">
    <thead>
        <tr style="text-align: left; color: var(--slate-400); border-bottom: 1px solid rgba(255,255,255,0.08);">
            <th style="padding: 0.6rem 0.5rem; font-weight: 500;">Name</th>
            <th style="padding: 0.6rem 0.5rem; font-weight: 500;">Website</th>
            <th style="padding: 0.6rem 0.5rem; font-weight: 500; width: 80px;">Active</th>
            <th style="padding: 0.6rem 0.5rem; font-weight: 500; width: 200px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model.Partners)
        {
            <tr style="border-bottom: 1px solid rgba(255,255,255,0.04); color: white;">
                <td style="padding: 0.6rem 0.5rem;">
                    <form method="post" asp-page-handler="Edit" asp-route-id="@p.Id" style="display:flex; gap:0.4rem;">
                        @Html.AntiForgeryToken()
                        <input name="name" value="@p.Name" style="flex:1; padding: 0.35rem 0.5rem; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 4px; color: white; font-size: 0.85rem;" />
                        <input name="websiteUrl" value="@p.WebsiteUrl" placeholder="https://…" style="flex:1; padding: 0.35rem 0.5rem; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 4px; color: white; font-size: 0.85rem;" />
                        <button type="submit" style="background: transparent; color: #93b4ff; border: 1px solid rgba(147,180,255,0.3); padding: 0.3rem 0.7rem; border-radius: 4px; cursor: pointer; font-size: 0.8rem;">Save</button>
                    </form>
                </td>
                <td style="padding: 0.6rem 0.5rem; max-width: 240px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                    @if (!string.IsNullOrEmpty(p.WebsiteUrl))
                    {
                        <a href="@p.WebsiteUrl" target="_blank" rel="noopener" style="color: #93b4ff; font-size: 0.8rem;">@p.WebsiteUrl</a>
                    }
                </td>
                <td style="padding: 0.6rem 0.5rem;">@(p.IsActive ? "●" : "○")</td>
                <td style="padding: 0.6rem 0.5rem;">
                    <form method="post" asp-page-handler="Toggle" asp-route-id="@p.Id" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" style="background: transparent; color: #93b4ff; border: none; cursor: pointer; font-size: 0.85rem;">Toggle active</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (Model.TotalPages > 1)
{
    <div style="margin-top: 1.5rem; display: flex; justify-content: space-between; align-items: center; font-size: 0.85rem; color: var(--slate-400);">
        <span>Page @Model.PageIndex of @Model.TotalPages</span>
        <span style="display: flex; gap: 0.5rem;">
            @if (Model.PageIndex > 1)
            {
                <a href="?q=@Model.Query&page=@(Model.PageIndex - 1)" style="color: #93b4ff;">← Prev</a>
            }
            @if (Model.PageIndex < Model.TotalPages)
            {
                <a href="?q=@Model.Query&page=@(Model.PageIndex + 1)" style="color: #93b4ff;">Next →</a>
            }
        </span>
    </div>
}
