@page
@model TheSwitchboard.Web.Pages.Admin.Partners.IndexModel
@{
    ViewData["Title"] = "Partners / Roster";
    Layout = "_AdminLayout";
}

<h1 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 1.5rem;">Roster</h1>

<form method="post" asp-page-handler="Create" style="display: flex; gap: 0.75rem; margin-bottom: 1.5rem; align-items: end;">
    @Html.AntiForgeryToken()
    <div style="flex:1">
        <label style="display: block; font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--slate-400); margin-bottom: 0.35rem;">Add partner</label>
        <input name="name" required style="width: 100%; padding: 0.5rem 0.7rem; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 6px; color: white; font-size: 0.9rem;" />
    </div>
    <button type="submit" style="background: #3b82f6; color: white; border: none; padding: 0.55rem 1.1rem; border-radius: 6px; font-weight: 600; cursor: pointer; font-size: 0.9rem;">Add</button>
</form>

<table style="width: 100%; border-collapse: collapse; font-size: 0.9rem;">
    <thead>
        <tr style="text-align: left; color: var(--slate-400); border-bottom: 1px solid rgba(255,255,255,0.08);">
            <th style="padding: 0.6rem 0.5rem; font-weight: 500;">Name</th>
            <th style="padding: 0.6rem 0.5rem; font-weight: 500;">Sort</th>
            <th style="padding: 0.6rem 0.5rem; font-weight: 500;">Active</th>
            <th style="padding: 0.6rem 0.5rem; font-weight: 500;"></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model.Partners)
        {
            <tr style="border-bottom: 1px solid rgba(255,255,255,0.04); color: white;">
                <td style="padding: 0.6rem 0.5rem;">@p.CompanyName</td>
                <td style="padding: 0.6rem 0.5rem; font-variant-numeric: tabular-nums;">@p.SortOrder</td>
                <td style="padding: 0.6rem 0.5rem;">@(p.IsActive ? "●" : "○")</td>
                <td style="padding: 0.6rem 0.5rem;">
                    <form method="post" asp-page-handler="Toggle" asp-route-id="@p.Id" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" style="background: transparent; color: #93b4ff; border: none; cursor: pointer; font-size: 0.85rem;">Toggle</button>
                    </form>
                    <form method="post" asp-page-handler="Delete" asp-route-id="@p.Id" style="display:inline; margin-left: 0.5rem;">
                        @Html.AntiForgeryToken()
                        <button type="submit" style="background: transparent; color: #ef4444; border: none; cursor: pointer; font-size: 0.85rem;">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
