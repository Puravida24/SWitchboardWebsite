@page
@model TheSwitchboard.Web.Pages.Admin.Reports.TrendsModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Trends";
    var nonce = TheSwitchboard.Web.Middleware.CspNonceMiddleware.GetNonce(HttpContext);
    var changeColor = Model.Series.ChangePct >= 0 ? "#10b981" : "#ef4444";
    var changeSign = Model.Series.ChangePct >= 0 ? "+" : "";
}

<div style="max-width: 1400px;">
  <h1 style="font-size: 1.5rem; font-weight: 700; color: white; margin-bottom: 0.25rem;">Trends</h1>
  <p style="color: var(--slate-500); margin-bottom: 1.5rem;">Pick a metric, pick a window — compared against the prior period of equal length.</p>

  <form method="get" style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1.5rem; font-size: 0.75rem; align-items: center;">
    <label style="color: var(--slate-500);">Metric
      <select name="metric" style="margin-left: 0.375rem; padding: 0.375rem 0.5rem; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.08); border-radius: 0.25rem; color: white;">
        @foreach (var m in TheSwitchboard.Web.Pages.Admin.Reports.TrendsModel.Metrics)
        {
          <option value="@m" selected="@(m == Model.Metric)">@m</option>
        }
      </select>
    </label>
    @foreach (var d in new[] { 7, 14, 30, 90 })
    {
      var active = Model.WindowDays == d;
      <a href="?metric=@Model.Metric&days=@d" style="padding: 0.375rem 0.75rem; border-radius: 0.25rem; text-decoration: none;
         background: @(active ? "rgba(59,130,246,0.2)" : "rgba(255,255,255,0.03)");
         color: @(active ? "white" : "var(--slate-400)");
         border: 1px solid @(active ? "rgba(59,130,246,0.4)" : "rgba(255,255,255,0.05)");">@(d)d</a>
    }
    <button type="submit" style="padding: 0.375rem 1rem; border-radius: 0.25rem; background: rgba(59,130,246,0.2); border: 1px solid rgba(59,130,246,0.4); color: white; cursor: pointer;">Apply</button>
  </form>

  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 1.5rem;">
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.25rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">Current total</div>
      <div style="font-size: 1.75rem; font-weight: 700; color: white;">@Model.Series.CurrentTotal</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.25rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">Prior period</div>
      <div style="font-size: 1.75rem; font-weight: 700; color: var(--slate-500);">@Model.Series.PreviousTotal</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.25rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">Change</div>
      <div style="font-size: 1.75rem; font-weight: 700; color: @changeColor;">@changeSign@(Model.Series.ChangePct)%</div>
    </div>
  </div>

  <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1rem; height: 420px;">
    <canvas id="trends-chart" style="height: 100%;"></canvas>
  </div>
</div>

<script nonce="@nonce" src="/js/vendor/chart.min.js"></script>
<script nonce="@nonce">
  (function () {
    if (typeof Chart === 'undefined') return;
    var data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
    {
        labels = Model.Series.Days.Select(d => d.ToString("MMM d")).ToArray(),
        current = Model.Series.Current,
        previous = Model.Series.Previous,
        metric = Model.Metric
    }));
    new Chart(document.getElementById('trends-chart'), {
      type: 'line',
      data: {
        labels: data.labels,
        datasets: [
          { label: 'Current ' + data.metric, data: data.current,  borderColor: '#3b82f6', backgroundColor: '#3b82f622', fill: true, tension: 0.3, borderWidth: 2 },
          { label: 'Prior period',            data: data.previous, borderColor: 'rgba(255,255,255,0.25)', borderDash: [6, 4], fill: false, tension: 0.3, borderWidth: 2 }
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { position: 'top', labels: { color: '#cbd5e1' } } },
        scales: {
          x: { ticks: { color: '#64748b' }, grid: { color: 'rgba(255,255,255,0.04)' } },
          y: { ticks: { color: '#64748b' }, grid: { color: 'rgba(255,255,255,0.04)' }, beginAtZero: true }
        }
      }
    });
  })();
</script>
