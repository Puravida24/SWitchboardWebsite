@page
@model TheSwitchboard.Web.Pages.Admin.Reports.ErrorsModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "JS errors";
}

<div style="max-width: 1200px;">
  <h1 style="font-size: 1.5rem; font-weight: 700; color: white; margin-bottom: 0.25rem;">JS errors</h1>
  <p style="color: var(--slate-500); margin-bottom: 1.5rem;">
    Uncaught exceptions and unhandled promise rejections, grouped by fingerprint (sha256 of message + source + line).
    Stack traces are PII-redacted before persist.
  </p>

  <div style="display: flex; gap: 0.5rem; margin-bottom: 1.5rem;">
    @foreach (var d in new[] { 1, 7, 30, 90 })
    {
      var active = Model.WindowDays == d;
      <a href="?days=@d" style="padding: 0.375rem 0.75rem; border-radius: 0.375rem; font-size: 0.75rem; text-decoration: none;
         background: @(active ? "rgba(59,130,246,0.2)" : "rgba(255,255,255,0.03)");
         color: @(active ? "white" : "var(--slate-400)");
         border: 1px solid @(active ? "rgba(59,130,246,0.4)" : "rgba(255,255,255,0.05)");">
        @(d == 1 ? "24h" : $"{d}d")
      </a>
    }
  </div>

  <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; overflow: hidden;">
    <div style="padding: 1rem 1.25rem; border-bottom: 1px solid rgba(255,255,255,0.05);">
      <h2 style="font-size: 0.875rem; font-weight: 600; color: white;">@Model.Errors.Count unique errors</h2>
    </div>
    @if (Model.Errors.Count == 0)
    {
      <div style="padding: 2rem; color: var(--slate-500); font-size: 0.875rem;">
        No JS errors captured in this window. Quiet is good.
      </div>
    }
    else
    {
      <table style="width: 100%; border-collapse: collapse; font-size: 0.875rem;">
        <thead>
          <tr style="color: var(--slate-500); text-transform: uppercase; font-size: 0.625rem; letter-spacing: 0.1em;">
            <th style="text-align: left; padding: 0.75rem 1.25rem;">Message</th>
            <th style="text-align: left; padding: 0.75rem 1.25rem;">Source</th>
            <th style="text-align: right; padding: 0.75rem 1.25rem;">Occurrences</th>
            <th style="text-align: right; padding: 0.75rem 1.25rem;">Sessions</th>
            <th style="text-align: left; padding: 0.75rem 1.25rem;">Last seen</th>
            <th style="text-align: left; padding: 0.75rem 1.25rem;">Fingerprint</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var e in Model.Errors)
          {
            <tr style="border-top: 1px solid rgba(255,255,255,0.04); color: var(--slate-300);">
              <td style="padding: 0.75rem 1.25rem; color: white;">@e.Message</td>
              <td style="padding: 0.75rem 1.25rem; font-family: ui-monospace, monospace; color: var(--slate-500); font-size: 0.75rem;">@(e.Source ?? "∅")@(e.Line is int ln ? $":{ln}" : "")</td>
              <td style="padding: 0.75rem 1.25rem; text-align: right; color: white; font-weight: 600;">@e.Occurrences</td>
              <td style="padding: 0.75rem 1.25rem; text-align: right; color: var(--slate-500);">@e.DistinctSessions</td>
              <td style="padding: 0.75rem 1.25rem; color: var(--slate-500); font-size: 0.75rem;">@(e.LastSeenAt?.ToString("MMM d HH:mm") ?? "—")</td>
              <td style="padding: 0.75rem 1.25rem; font-family: ui-monospace, monospace; color: var(--slate-500); font-size: 0.75rem;">@e.Fingerprint</td>
            </tr>
          }
        </tbody>
      </table>
    }
  </div>
</div>
