@page
@model TheSwitchboard.Web.Pages.Admin.Reports.Forms.FunnelModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Form funnel";
    var maxReach = Model.Report.Steps.Count == 0 ? 1 : Math.Max(1, Model.Report.Steps.Max(s => s.Reached));
}

<div style="max-width: 1200px;">
  <h1 style="font-size: 1.5rem; font-weight: 700; color: white; margin-bottom: 0.25rem;">Form funnel — @Model.FormId</h1>
  <p style="color: var(--slate-500); margin-bottom: 1.5rem;">
    Per-field drop-off for the contact form. Fields shown in fill order; bars scale to the widest step.
    Red flag = &gt;30% drop from the previous step.
  </p>

  <form method="get" style="display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 1.5rem; font-size: 0.75rem; align-items: center;">
    <label style="color: var(--slate-500);">
      Form
      <select name="formId" style="margin-left: 0.375rem; padding: 0.375rem 0.5rem; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.08); border-radius: 0.25rem; color: white;">
        @if (!Model.AvailableForms.Contains(Model.FormId))
        {
          <option value="@Model.FormId" selected>@Model.FormId</option>
        }
        @foreach (var f in Model.AvailableForms)
        {
          <option value="@f" selected="@(f == Model.FormId)">@f</option>
        }
      </select>
    </label>
    @foreach (var d in new[] { 1, 7, 30, 90 })
    {
      var active = Model.WindowDays == d;
      <a href="?formId=@Model.FormId&days=@d" style="padding: 0.375rem 0.75rem; border-radius: 0.375rem; text-decoration: none;
         background: @(active ? "rgba(59,130,246,0.2)" : "rgba(255,255,255,0.03)");
         color: @(active ? "white" : "var(--slate-400)");
         border: 1px solid @(active ? "rgba(59,130,246,0.4)" : "rgba(255,255,255,0.05)");">
        @(d == 1 ? "24h" : $"{d}d")
      </a>
    }
  </form>

  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.25rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">Starts</div>
      <div style="font-size: 1.75rem; font-weight: 700; color: white;">@Model.Report.Starts</div>
      <div style="font-size: 0.75rem; color: var(--slate-600); margin-top: 0.25rem;">focused the first field</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.25rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">Submits</div>
      <div style="font-size: 1.75rem; font-weight: 700; color: #10b981;">@Model.Report.Submits</div>
      <div style="font-size: 0.75rem; color: var(--slate-600); margin-top: 0.25rem;">form.submit fired</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.25rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">Abandons</div>
      <div style="font-size: 1.75rem; font-weight: 700; color: #f59e0b;">@Model.Report.Abandons</div>
      <div style="font-size: 0.75rem; color: var(--slate-600); margin-top: 0.25rem;">focused but left</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.25rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">Conversion</div>
      <div style="font-size: 1.75rem; font-weight: 700; color: #3b82f6;">@(Model.Report.Starts == 0 ? "—" : ($"{Math.Round(100.0 * Model.Report.Submits / Math.Max(1, Model.Report.Starts))}%"))</div>
      <div style="font-size: 0.75rem; color: var(--slate-600); margin-top: 0.25rem;">submits / starts</div>
    </div>
  </div>

  <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; overflow: hidden;">
    <div style="padding: 1rem 1.25rem; border-bottom: 1px solid rgba(255,255,255,0.05);">
      <h2 style="font-size: 0.875rem; font-weight: 600; color: white;">Per-field funnel</h2>
    </div>
    @if (Model.Report.Steps.Count == 0)
    {
      <div style="padding: 2rem; color: var(--slate-500); font-size: 0.875rem;">
        No form interactions captured yet in this window. Try focusing a field on <code style="color: var(--slate-300);">/</code> — events stream in within seconds.
      </div>
    }
    else
    {
      <table style="width: 100%; border-collapse: collapse; font-size: 0.875rem;">
        <thead>
          <tr style="color: var(--slate-500); text-transform: uppercase; font-size: 0.625rem; letter-spacing: 0.1em;">
            <th style="text-align: left; padding: 0.75rem 1.25rem;">Field</th>
            <th style="text-align: left; padding: 0.75rem 1.25rem;">Reached</th>
            <th style="text-align: right; padding: 0.75rem 1.25rem;">Completed</th>
            <th style="text-align: right; padding: 0.75rem 1.25rem;">Errors</th>
            <th style="text-align: right; padding: 0.75rem 1.25rem;">Pasted</th>
            <th style="text-align: right; padding: 0.75rem 1.25rem;">Avg dwell</th>
            <th style="text-align: right; padding: 0.75rem 1.25rem;">Drop-off</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var s in Model.Report.Steps)
          {
            var width = Math.Round((double)s.Reached / maxReach * 100, 1);
            var drop = s.DropOffPct;
            var dropColor = drop >= 30 ? "#ef4444" : (drop >= 15 ? "#f59e0b" : "var(--slate-500)");
            <tr style="border-top: 1px solid rgba(255,255,255,0.04); color: var(--slate-300);">
              <td style="padding: 0.75rem 1.25rem; font-family: ui-monospace, monospace; color: white;">@s.FieldName</td>
              <td style="padding: 0.5rem 1.25rem; width: 40%;">
                <div style="background: rgba(255,255,255,0.04); height: 10px; border-radius: 999px; overflow: hidden;">
                  <div style="background: linear-gradient(90deg, #3b82f6, #60a5fa); height: 100%; width: @(width.ToString("0.#"))%;"></div>
                </div>
                <div style="font-size: 0.75rem; color: var(--slate-500); margin-top: 0.25rem;">@s.Reached sessions</div>
              </td>
              <td style="padding: 0.75rem 1.25rem; text-align: right;">@s.Completed</td>
              <td style="padding: 0.75rem 1.25rem; text-align: right; color: @(s.Errored > 0 ? "#ef4444" : "var(--slate-500)");">@s.Errored</td>
              <td style="padding: 0.75rem 1.25rem; text-align: right; color: var(--slate-500);">@s.PastedCount</td>
              <td style="padding: 0.75rem 1.25rem; text-align: right; color: var(--slate-500);">@(s.AvgDwellMs == 0 ? "—" : $"{s.AvgDwellMs / 1000.0:0.#}s")</td>
              <td style="padding: 0.75rem 1.25rem; text-align: right; font-weight: 600; color: @dropColor;">@(drop > 0 ? $"-{drop}%" : "—")</td>
            </tr>
          }
        </tbody>
      </table>
    }
  </div>
</div>
