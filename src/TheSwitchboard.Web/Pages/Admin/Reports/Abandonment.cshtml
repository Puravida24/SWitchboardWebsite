@page
@model TheSwitchboard.Web.Pages.Admin.Reports.AbandonmentModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Abandonment";
    var rate = Model.Report.TotalSessions == 0 ? 0 : Math.Round(100.0 * Model.Report.AbandonedSessions / Model.Report.TotalSessions);
}

<div style="max-width: 1200px;">
  <h1 style="font-size: 1.5rem; font-weight: 700; color: white; margin-bottom: 0.25rem;">Abandonment</h1>
  <p style="color: var(--slate-500); margin-bottom: 1.5rem;">
    Where people bail. Abandoned-field ranking comes from fields that got focus but never cleanly blurred before tab close. Exit paths come from the last tracked path per session.
  </p>

  <div style="display: flex; gap: 0.5rem; margin-bottom: 1.5rem;">
    @foreach (var d in new[] { 1, 7, 30, 90 })
    {
      var active = Model.WindowDays == d;
      <a href="?days=@d" style="padding: 0.375rem 0.75rem; border-radius: 0.375rem; font-size: 0.75rem; text-decoration: none;
         background: @(active ? "rgba(59,130,246,0.2)" : "rgba(255,255,255,0.03)");
         color: @(active ? "white" : "var(--slate-400)");
         border: 1px solid @(active ? "rgba(59,130,246,0.4)" : "rgba(255,255,255,0.05)");">
        @(d == 1 ? "24h" : $"{d}d")
      </a>
    }
  </div>

  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.25rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">Sessions in window</div>
      <div style="font-size: 1.75rem; font-weight: 700; color: white;">@Model.Report.TotalSessions</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.25rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">Abandoned form</div>
      <div style="font-size: 1.75rem; font-weight: 700; color: #f59e0b;">@Model.Report.AbandonedSessions</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.25rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">Abandonment rate</div>
      <div style="font-size: 1.75rem; font-weight: 700; color: #ef4444;">@rate%</div>
    </div>
  </div>

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
    <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; overflow: hidden;">
      <div style="padding: 1rem 1.25rem; border-bottom: 1px solid rgba(255,255,255,0.05);"><h2 style="font-size: 0.875rem; font-weight: 600; color: white;">Fields abandoned most</h2></div>
      @if (Model.Report.AbandonedFields.Count == 0)
      {
        <div style="padding: 1.5rem; color: var(--slate-500); font-size: 0.875rem;">No form abandons in this window.</div>
      }
      else
      {
        <table style="width: 100%; border-collapse: collapse; font-size: 0.875rem;">
          <thead>
            <tr style="color: var(--slate-500); text-transform: uppercase; font-size: 0.625rem; letter-spacing: 0.1em;">
              <th style="text-align: left; padding: 0.625rem 1rem;">Field</th>
              <th style="text-align: right; padding: 0.625rem 1rem;">Count</th>
              <th style="text-align: right; padding: 0.625rem 1rem;">Avg dwell</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var r in Model.Report.AbandonedFields)
            {
              <tr style="border-top: 1px solid rgba(255,255,255,0.04); color: var(--slate-300);">
                <td style="padding: 0.625rem 1rem; font-family: ui-monospace, monospace; color: white;">@r.FieldName</td>
                <td style="padding: 0.625rem 1rem; text-align: right;">@r.Count</td>
                <td style="padding: 0.625rem 1rem; text-align: right; color: var(--slate-500);">@(r.AvgDwellMs == 0 ? "—" : $"{r.AvgDwellMs / 1000.0:0.#}s")</td>
              </tr>
            }
          </tbody>
        </table>
      }
    </div>

    <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; overflow: hidden;">
      <div style="padding: 1rem 1.25rem; border-bottom: 1px solid rgba(255,255,255,0.05);"><h2 style="font-size: 0.875rem; font-weight: 600; color: white;">Top exit paths</h2></div>
      @if (Model.Report.TopExitPaths.Count == 0)
      {
        <div style="padding: 1.5rem; color: var(--slate-500); font-size: 0.875rem;">No exits tracked in this window.</div>
      }
      else
      {
        <table style="width: 100%; border-collapse: collapse; font-size: 0.875rem;">
          <thead>
            <tr style="color: var(--slate-500); text-transform: uppercase; font-size: 0.625rem; letter-spacing: 0.1em;">
              <th style="text-align: left; padding: 0.625rem 1rem;">Path</th>
              <th style="text-align: right; padding: 0.625rem 1rem;">Exits</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var r in Model.Report.TopExitPaths)
            {
              <tr style="border-top: 1px solid rgba(255,255,255,0.04); color: var(--slate-300);">
                <td style="padding: 0.625rem 1rem; font-family: ui-monospace, monospace;">@r.Path</td>
                <td style="padding: 0.625rem 1rem; text-align: right; color: white; font-weight: 600;">@r.Exits</td>
              </tr>
            }
          </tbody>
        </table>
      }
    </div>
  </div>
</div>
