@page
@model TheSwitchboard.Web.Pages.Admin.Reports.AttributionModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Attribution";
}

<div style="max-width: 1200px;">
  <h1 style="font-size: 1.5rem; font-weight: 700; color: white; margin-bottom: 0.25rem;">Attribution</h1>
  <p style="color: var(--slate-500); margin-bottom: 2rem;">
    Where landing sessions come from. First-touch. One row per unique session — grouped by UTM source / medium / campaign with click-ID overlays.
  </p>

  <!-- Window selector -->
  <div style="display: flex; gap: 0.5rem; margin-bottom: 1.5rem;">
    @foreach (var d in new[] { 1, 7, 30, 90 })
    {
      var active = Model.WindowDays == d;
      <a href="?days=@d" style="padding: 0.375rem 0.75rem; border-radius: 0.375rem; font-size: 0.75rem; text-decoration: none;
         background: @(active ? "rgba(59,130,246,0.2)" : "rgba(255,255,255,0.03)");
         color: @(active ? "white" : "var(--slate-400)");
         border: 1px solid @(active ? "rgba(59,130,246,0.4)" : "rgba(255,255,255,0.05)");">
        @(d == 1 ? "24h" : $"{d}d")
      </a>
    }
  </div>

  <!-- Summary strip -->
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
    @{
      (string label, int value, string hint)[] tiles =
      {
        ("Landing sessions",    Model.Summary.TotalSessions,         "total landings in window"),
        ("With attribution",    Model.Summary.SessionsWithAttribution, "UTM or click-id present"),
        ("Google Ads (gclid)",  Model.Summary.GoogleAds,             "paid search"),
        ("Meta Ads (fbclid)",   Model.Summary.MetaAds,               "Facebook / Instagram"),
        ("Microsoft Ads",       Model.Summary.MicrosoftAds,          "Bing, msclkid"),
        ("Direct / organic",    Model.Summary.DirectOrOrganic,       "no campaign params")
      };
    }
    @foreach (var tile in tiles)
    {
      <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.25rem;">
        <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">@tile.label</div>
        <div style="font-size: 1.75rem; font-weight: 700; color: white;">@tile.value</div>
        <div style="font-size: 0.75rem; color: var(--slate-600); margin-top: 0.25rem;">@tile.hint</div>
      </div>
    }
  </div>

  <!-- Breakdown table -->
  <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; overflow: hidden; margin-bottom: 2rem;">
    <div style="padding: 1rem 1.25rem; border-bottom: 1px solid rgba(255,255,255,0.05);">
      <h2 style="font-size: 0.875rem; font-weight: 600; color: white;">Breakdown (landings grouped by source → medium → campaign)</h2>
    </div>
    @if (Model.Rows.Count == 0)
    {
      <div style="padding: 2rem; color: var(--slate-500); font-size: 0.875rem;">
        No landings captured yet in this window. Visit the site with
        <code style="color: var(--slate-300);">?utm_source=test&utm_campaign=smoke</code> to generate one.
      </div>
    }
    else
    {
      <table style="width: 100%; border-collapse: collapse; font-size: 0.875rem;">
        <thead>
          <tr style="color: var(--slate-500); text-transform: uppercase; font-size: 0.625rem; letter-spacing: 0.1em;">
            <th style="text-align: left; padding: 0.75rem 1.25rem;">Source</th>
            <th style="text-align: left; padding: 0.75rem 1.25rem;">Medium</th>
            <th style="text-align: left; padding: 0.75rem 1.25rem;">Campaign</th>
            <th style="text-align: right; padding: 0.75rem 1.25rem;">Sessions</th>
            <th style="text-align: right; padding: 0.75rem 1.25rem;">Pageviews</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var r in Model.Rows)
          {
            <tr style="border-top: 1px solid rgba(255,255,255,0.04); color: var(--slate-300);">
              <td style="padding: 0.75rem 1.25rem; font-family: ui-monospace, monospace;">@r.Source</td>
              <td style="padding: 0.75rem 1.25rem; font-family: ui-monospace, monospace; color: var(--slate-500);">@r.Medium</td>
              <td style="padding: 0.75rem 1.25rem; color: white;">@r.Campaign</td>
              <td style="padding: 0.75rem 1.25rem; text-align: right; font-weight: 600; color: white;">@r.Sessions</td>
              <td style="padding: 0.75rem 1.25rem; text-align: right; color: var(--slate-500);">@r.PageViews</td>
            </tr>
          }
        </tbody>
      </table>
    }
  </div>

  <!-- Paste-a-URL preview tool -->
  <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.5rem;">
    <h2 style="font-size: 0.875rem; font-weight: 600; color: white; margin-bottom: 0.5rem;">Paste a URL — preview attribution</h2>
    <p style="color: var(--slate-500); font-size: 0.75rem; margin-bottom: 1rem;">
      Confirm a campaign URL will be captured correctly before pasting it into an ad platform.
    </p>
    <form method="get" style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
      <input type="hidden" name="days" value="@Model.WindowDays" />
      <input type="url" name="url" value="@(Model.PreviewUrl ?? "")"
             placeholder="https://www.theswitchboardmarketing.com/?utm_source=linkedin&utm_campaign=launch&gclid=abc"
             style="flex: 1; min-width: 320px; padding: 0.5rem 0.75rem; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.08); border-radius: 0.375rem; color: white; font-family: ui-monospace, monospace; font-size: 0.75rem;" />
      <button type="submit" style="padding: 0.5rem 1rem; border-radius: 0.375rem; font-size: 0.875rem; background: rgba(59,130,246,0.2); border: 1px solid rgba(59,130,246,0.4); color: white; cursor: pointer;">Preview</button>
    </form>

    @if (Model.Preview is not null)
    {
      <div style="margin-top: 1rem; padding: 1rem; background: rgba(0,0,0,0.3); border-radius: 0.375rem;">
        <table style="width: 100%; font-size: 0.75rem; color: var(--slate-300);">
          @{
            (string k, string? v)[] pairs =
            {
              ("utm_source",   Model.Preview.UtmSource),
              ("utm_medium",   Model.Preview.UtmMedium),
              ("utm_campaign", Model.Preview.UtmCampaign),
              ("utm_term",     Model.Preview.UtmTerm),
              ("utm_content",  Model.Preview.UtmContent),
              ("gclid",        Model.Preview.Gclid),
              ("fbclid",       Model.Preview.Fbclid),
              ("msclkid",      Model.Preview.Msclkid)
            };
          }
          @foreach (var p in pairs)
          {
            <tr>
              <td style="padding: 0.25rem 0.5rem; color: var(--slate-500); font-family: ui-monospace, monospace; width: 150px;">@p.k</td>
              <td style="padding: 0.25rem 0.5rem; font-family: ui-monospace, monospace; color: @(p.v is null ? "var(--slate-600)" : "white");">
                @(p.v ?? "∅")
              </td>
            </tr>
          }
        </table>
      </div>
    }
  </div>
</div>
