@page
@model TheSwitchboard.Web.Pages.Admin.Reports.ComplianceModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Compliance";
    var captureColor = Model.Report.CaptureRatePct >= 95 ? "#10b981"
                     : Model.Report.CaptureRatePct >= 85 ? "#f59e0b" : "#ef4444";
    var phoneColor = Model.Report.PhoneCaptureRatePct >= 95 ? "#10b981"
                   : Model.Report.PhoneCaptureRatePct >= 85 ? "#f59e0b" : "#ef4444";
}

<div style="max-width: 1200px;">
  <h1 style="font-size: 1.5rem; font-weight: 700; color: white; margin-bottom: 0.25rem;">Compliance</h1>
  <p style="color: var(--slate-500); margin-bottom: 1.5rem;">
    TCPA consent capture rate — the critical metric is <strong>phone-consent capture</strong>,
    because every phone-providing form submission without a valid cert is class-action exposure at dial time.
  </p>

  <div style="display: flex; gap: 0.5rem; margin-bottom: 1.5rem;">
    @foreach (var d in new[] { 1, 7, 30, 90 })
    {
      var active = Model.WindowDays == d;
      <a href="?days=@d" style="padding: 0.375rem 0.75rem; border-radius: 0.375rem; font-size: 0.75rem; text-decoration: none;
         background: @(active ? "rgba(59,130,246,0.2)" : "rgba(255,255,255,0.03)");
         color: @(active ? "white" : "var(--slate-400)");
         border: 1px solid @(active ? "rgba(59,130,246,0.4)" : "rgba(255,255,255,0.05)");">
        @(d == 1 ? "24h" : $"{d}d")
      </a>
    }
  </div>

  @if (Model.Report.PhoneProvidingSubmissions > 0 && Model.Report.PhoneCaptureRatePct < 95)
  {
    <div style="background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.4); border-radius: 0.5rem; padding: 1rem 1.25rem; margin-bottom: 1.5rem; color: #fecaca;">
      <strong style="color: #ef4444;">⚠ Phone-consent capture below 95%</strong> —
      @(Model.Report.PhoneProvidingSubmissions - Model.Report.PhoneCertifiedSubmissions) phone-providing submissions lack a consent certificate in this window. Investigate immediately.
    </div>
  }

  @if (Model.Report.UnregisteredActiveVersions > 0)
  {
    <div style="background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.4); border-radius: 0.5rem; padding: 1rem 1.25rem; margin-bottom: 1.5rem; color: #fde68a;">
      <strong style="color: #f59e0b;">⚠ Unregistered disclosure version detected</strong> —
      @Model.Report.UnregisteredActiveVersions active version(s) have status "auto-detected" and need legal review.
      <a href="/Admin/Reports/Disclosures" style="color: white; text-decoration: underline; margin-left: 0.5rem;">Review →</a>
    </div>
  }

  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.25rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">
        Overall capture rate
        <span class="tb-help" tabindex="0" data-tip="% of all form submissions in this window that have a linked consent certificate. 100 % means every submission is provably TCPA-compliant at dial time. Dips usually mean the client-side /api/tracking/consent POST failed — check Compliance + Seq.">?</span>
      </div>
      <div style="font-size: 1.75rem; font-weight: 700; color: @captureColor;">@Model.Report.CaptureRatePct%</div>
      <div style="font-size: 0.75rem; color: var(--slate-600); margin-top: 0.25rem;">@Model.Report.CertifiedSubmissions / @Model.Report.TotalSubmissions submissions</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(239,68,68,0.3); border-radius: 0.5rem; padding: 1.25rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: #ef4444; margin-bottom: 0.5rem;">
        Phone-consent capture · TCPA critical
        <span class="tb-help" tabindex="0" data-tip="% of phone-providing submissions that also have a consent certificate. This is the metric that matters for TCPA: dialing a prospect without a cert is class-action exposure. Must stay ≥ 95 %. Red alert fires below that.">?</span>
      </div>
      <div style="font-size: 1.75rem; font-weight: 700; color: @phoneColor;">@Model.Report.PhoneCaptureRatePct%</div>
      <div style="font-size: 0.75rem; color: var(--slate-600); margin-top: 0.25rem;">@Model.Report.PhoneCertifiedSubmissions / @Model.Report.PhoneProvidingSubmissions phone-providing</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.25rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">
        Total certs issued
        <span class="tb-help" tabindex="0" data-tip="Raw count of ConsentCertificate rows minted in this window. A cert is minted the moment a visitor submits the contact form with consent. Can exceed submission count if the form was submitted multiple times by the same session.">?</span>
      </div>
      <div style="font-size: 1.75rem; font-weight: 700; color: white;">@Model.Report.TotalCerts</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.25rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">
        Suspicious bot rate
        <span class="tb-help" tabindex="0" data-tip="% of certs flagged IsSuspiciousBot = true — heuristics across user-agent, behavioral signals, known proxy ASN. High rate doesn't invalidate certs but signals someone's stuffing the form. Investigate at /Admin/Reports/Visitors filter IsBot.">?</span>
      </div>
      <div style="font-size: 1.75rem; font-weight: 700; color: @(Model.Report.BotRatePct > 5 ? "#f59e0b" : "#10b981");">@Model.Report.BotRatePct%</div>
      <div style="font-size: 0.75rem; color: var(--slate-600); margin-top: 0.25rem;">@Model.Report.SuspiciousBotCerts of @Model.Report.TotalCerts</div>
    </div>
  </div>

  <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
    <a href="/Admin/Reports/Certificates" style="flex: 1; min-width: 280px; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.5rem; text-decoration: none; color: var(--slate-300); display: block;">
      <div style="font-size: 0.875rem; font-weight: 600; color: white;">Certificate list →</div>
      <div style="font-size: 0.75rem; color: var(--slate-500); margin-top: 0.25rem;">Every cert, searchable by status and date. Deep-link into the proof record.</div>
    </a>
    <a href="/Admin/Reports/Disclosures" style="flex: 1; min-width: 280px; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.5rem; text-decoration: none; color: var(--slate-300); display: block;">
      <div style="font-size: 0.875rem; font-weight: 600; color: white;">Disclosure versions →</div>
      <div style="font-size: 0.75rem; color: var(--slate-500); margin-top: 0.25rem;">Review auto-detected text-hash versions, register for legal, retire old versions.</div>
    </a>
  </div>
</div>
