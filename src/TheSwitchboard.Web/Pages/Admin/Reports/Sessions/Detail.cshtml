@page
@model TheSwitchboard.Web.Pages.Admin.Reports.Sessions.DetailModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Session detail";
    var nonce = TheSwitchboard.Web.Middleware.CspNonceMiddleware.GetNonce(HttpContext);
}

<div style="max-width: 1400px;">
  <a href="/Admin/Reports/Sessions" style="font-size: 0.75rem; color: var(--slate-500); text-decoration: none;">← All sessions</a>
  <h1 style="font-size: 1.5rem; font-weight: 700; color: white; margin-top: 0.5rem; margin-bottom: 0.25rem;">Session detail</h1>
  <p style="color: var(--slate-500); margin-bottom: 1.5rem; font-family: ui-monospace, monospace;">@Model.Session!.Id</p>

  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.25rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">Pageviews</div>
      <div style="font-size: 1.5rem; font-weight: 700; color: white;">@Model.PageViewCount</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.25rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">Clicks</div>
      <div style="font-size: 1.5rem; font-weight: 700; color: white;">@Model.ClickCount</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.25rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">Form events</div>
      <div style="font-size: 1.5rem; font-weight: 700; color: white;">@Model.FormEventCount</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.25rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">JS errors</div>
      <div style="font-size: 1.5rem; font-weight: 700; color: @(Model.ErrorCount > 0 ? "#ef4444" : "white");">@Model.ErrorCount</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.25rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">Converted</div>
      <div style="font-size: 1.5rem; font-weight: 700; color: @(Model.Session.Converted ? "#3b82f6" : "var(--slate-500)");">@(Model.Session.Converted ? "Yes" : "No")</div>
    </div>
  </div>

  <!-- rrweb player pane -->
  <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; overflow: hidden; margin-bottom: 1.5rem;">
    <div style="padding: 1rem 1.25rem; border-bottom: 1px solid rgba(255,255,255,0.05); display: flex; justify-content: space-between; align-items: center;">
      <h2 style="font-size: 0.875rem; font-weight: 600; color: white;">Session replay</h2>
      @if (Model.Replay is not null)
      {
        <span style="color: var(--slate-500); font-size: 0.75rem;">@Model.Replay.ChunkCount chunks · @(Model.Replay.ByteSize / 1024) KB · @(Model.Replay.DurationSeconds)s</span>
      }
    </div>
    @if (Model.Replay is null)
    {
      <div style="padding: 2rem; color: var(--slate-500); font-size: 0.875rem;">
        This session wasn&apos;t sampled for replay (rrweb records ~20% of sessions). Try visiting <code style="color: var(--slate-300);">/</code> in multiple incognito windows — hash-of-sid determines sample inclusion, so eventually one will land.
      </div>
    }
    else
    {
      <link rel="stylesheet" href="/js/vendor/rrweb-player.css" />
      <div id="sw-replay-player" style="width: 100%; min-height: 600px; background: #000;"></div>
      @if (Model.SubmitMomentUtc is not null)
      {
        <div style="padding: 0.75rem 1.25rem; border-top: 1px solid rgba(255,255,255,0.05); font-size: 0.75rem; color: #fbbf24;">
          ✦ Form submit fired at @Model.SubmitMomentUtc.Value.ToString("HH:mm:ss") — use the player&apos;s timeline to jump to that moment.
        </div>
      }
      <script nonce="@nonce" src="/js/vendor/rrweb.min.js"></script>
      <script nonce="@nonce" src="/js/vendor/rrweb-player.min.js"></script>
      <script nonce="@nonce">
        (async function () {
          try {
            const resp = await fetch('/Admin/Reports/Sessions/Detail?id=@Model.Session!.Id&handler=Chunks');
            if (!resp.ok) return;
            const data = await resp.json();
            const events = [];
            for (const c of (data.chunks || [])) {
              const bin = Uint8Array.from(atob(c.payloadBase64), ch => ch.charCodeAt(0));
              let bytes = bin;
              if (data.compressed) {
                try {
                  const ds = new DecompressionStream('gzip');
                  const raw = await new Response(new Blob([bin]).stream().pipeThrough(ds)).arrayBuffer();
                  bytes = new Uint8Array(raw);
                } catch (e) { /* uncompressed fallback */ }
              }
              try {
                const text = new TextDecoder().decode(bytes);
                const parsed = JSON.parse(text);
                if (Array.isArray(parsed)) events.push(...parsed);
              } catch (e) { /* skip malformed chunk */ }
            }
            if (events.length === 0) return;
            new rrwebPlayer({
              target: document.getElementById('sw-replay-player'),
              props: {
                events: events,
                autoPlay: false,
                showController: true,
                skipInactive: true,
                width: document.getElementById('sw-replay-player').clientWidth,
                height: 600
              }
            });
          } catch (e) { console.error('replay load failed', e); }
        })();
      </script>
    }
  </div>

  <!-- Timeline -->
  <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; overflow: hidden;">
    <div style="padding: 1rem 1.25rem; border-bottom: 1px solid rgba(255,255,255,0.05);">
      <h2 style="font-size: 0.875rem; font-weight: 600; color: white;">Timeline · @Model.Timeline.Count events</h2>
    </div>
    @if (Model.Timeline.Count == 0)
    {
      <div style="padding: 1.5rem; color: var(--slate-500); font-size: 0.875rem;">No events captured yet for this session.</div>
    }
    else
    {
      <div style="max-height: 500px; overflow-y: auto; padding: 0.5rem 0;">
        @foreach (var item in Model.Timeline)
        {
          var color = item.Kind switch
          {
            "pageview" => "#3b82f6",
            "click" => "var(--slate-400)",
            "rage-click" => "#ef4444",
            "dead-click" => "#f59e0b",
            "form:submit" => "#10b981",
            "form:abandon" => "#f59e0b",
            "error" => "#ef4444",
            _ => "var(--slate-400)"
          };
          <div style="display: flex; gap: 1rem; padding: 0.375rem 1.25rem; font-size: 0.75rem; border-bottom: 1px solid rgba(255,255,255,0.03);">
            <span style="color: var(--slate-500); font-family: ui-monospace, monospace; min-width: 100px;">@item.Ts.ToString("HH:mm:ss.fff")</span>
            <span style="color: @color; min-width: 110px; font-weight: 600;">@item.Kind</span>
            <span style="color: var(--slate-300); font-family: ui-monospace, monospace; min-width: 140px;">@item.Path</span>
            @if (!string.IsNullOrEmpty(item.Label))
            {
              <span style="color: var(--slate-500);">@item.Label</span>
            }
          </div>
        }
      </div>
    }
  </div>
</div>
