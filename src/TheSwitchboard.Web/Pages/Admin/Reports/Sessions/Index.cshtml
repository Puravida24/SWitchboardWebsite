@page
@model TheSwitchboard.Web.Pages.Admin.Reports.Sessions.IndexModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Sessions";
}

<div style="max-width: 1400px;">
  <h1 style="font-size: 1.5rem; font-weight: 700; color: white; margin-bottom: 0.25rem;">Sessions</h1>
  <p style="color: var(--slate-500); margin-bottom: 2rem;">
    One row per <code style="color: var(--slate-300);">sw_sid</code>. Bumps on every tracker event. Filter by device, bot, or converted below.
  </p>

  <!-- Summary tiles -->
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.25rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">Total</div>
      <div style="font-size: 1.75rem; font-weight: 700; color: white;">@Model.TotalSessions</div>
      <div style="font-size: 0.75rem; color: var(--slate-600); margin-top: 0.25rem;">all-time sessions</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.25rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">Humans</div>
      <div style="font-size: 1.75rem; font-weight: 700; color: #10b981;">@Model.HumanSessions</div>
      <div style="font-size: 0.75rem; color: var(--slate-600); margin-top: 0.25rem;">IsBot = false</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.25rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">Bots / Crawlers</div>
      <div style="font-size: 1.75rem; font-weight: 700; color: #f59e0b;">@Model.BotSessions</div>
      <div style="font-size: 0.75rem; color: var(--slate-600); margin-top: 0.25rem;">UA-heuristic</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.25rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">Converted</div>
      <div style="font-size: 1.75rem; font-weight: 700; color: #3b82f6;">@Model.ConvertedSessions</div>
      <div style="font-size: 0.75rem; color: var(--slate-600); margin-top: 0.25rem;">form submit fired</div>
    </div>
  </div>

  <!-- Filters -->
  <form method="get" style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1.5rem; font-size: 0.75rem;">
    <label style="color: var(--slate-500); display: flex; align-items: center; gap: 0.375rem;">
      Device
      <select name="device" style="padding: 0.375rem 0.5rem; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.08); border-radius: 0.25rem; color: white;">
        <option value="" selected="@(string.IsNullOrEmpty(Model.Device))">any</option>
        @foreach (var d in new[] { "desktop", "mobile", "tablet", "bot", "unknown" })
        {
          <option value="@d" selected="@(Model.Device == d)">@d</option>
        }
      </select>
    </label>
    <label style="color: var(--slate-500); display: flex; align-items: center; gap: 0.375rem;">
      Bots
      <select name="bot" style="padding: 0.375rem 0.5rem; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.08); border-radius: 0.25rem; color: white;">
        <option value="" selected="@(string.IsNullOrEmpty(Model.Bot))">show all</option>
        <option value="hide" selected="@(Model.Bot == "hide")">hide bots</option>
        <option value="only" selected="@(Model.Bot == "only")">bots only</option>
      </select>
    </label>
    <label style="color: var(--slate-500); display: flex; align-items: center; gap: 0.375rem;">
      Converted
      <select name="converted" style="padding: 0.375rem 0.5rem; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.08); border-radius: 0.25rem; color: white;">
        <option value="" selected="@(string.IsNullOrEmpty(Model.Converted))">show all</option>
        <option value="only" selected="@(Model.Converted == "only")">only converted</option>
        <option value="hide" selected="@(Model.Converted == "hide")">hide converted</option>
      </select>
    </label>
    <label style="color: var(--slate-500); display: flex; align-items: center; gap: 0.375rem;">
      Source
      <input type="text" name="source" value="@(Model.Source ?? "")" placeholder="e.g. linkedin"
             style="padding: 0.375rem 0.5rem; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.08); border-radius: 0.25rem; color: white; width: 160px;" />
    </label>
    <button type="submit" style="padding: 0.375rem 1rem; border-radius: 0.25rem; background: rgba(59,130,246,0.2); border: 1px solid rgba(59,130,246,0.4); color: white; cursor: pointer;">Apply</button>
    <a href="/Admin/Reports/Sessions" style="padding: 0.375rem 1rem; border-radius: 0.25rem; color: var(--slate-400); text-decoration: none; align-self: center;">clear</a>
  </form>

  <!-- Table -->
  <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; overflow: hidden;">
    @if (Model.Rows.Count == 0)
    {
      <div style="padding: 2rem; color: var(--slate-500); font-size: 0.875rem;">
        No sessions matching these filters yet.
      </div>
    }
    else
    {
      <table style="width: 100%; border-collapse: collapse; font-size: 0.75rem;">
        <thead>
          <tr style="color: var(--slate-500); text-transform: uppercase; font-size: 0.625rem; letter-spacing: 0.1em;">
            <th style="text-align: left; padding: 0.75rem 1rem;">Started</th>
            <th style="text-align: left; padding: 0.75rem 1rem;">Session</th>
            <th style="text-align: left; padding: 0.75rem 1rem;">Device</th>
            <th style="text-align: left; padding: 0.75rem 1rem;">Browser / OS</th>
            <th style="text-align: right; padding: 0.75rem 1rem;">PVs</th>
            <th style="text-align: right; padding: 0.75rem 1rem;">Events</th>
            <th style="text-align: left; padding: 0.75rem 1rem;">Source</th>
            <th style="text-align: left; padding: 0.75rem 1rem;">Status</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var s in Model.Rows)
          {
            <tr style="border-top: 1px solid rgba(255,255,255,0.04); color: var(--slate-300);">
              <td style="padding: 0.625rem 1rem; font-family: ui-monospace, monospace; color: var(--slate-400);" title="@s.StartedAt.ToString("u")">@s.StartedAt.ToString("MMM d HH:mm:ss")</td>
              <td style="padding: 0.625rem 1rem; font-family: ui-monospace, monospace; color: var(--slate-500);">@(s.Id.Length > 16 ? s.Id[..16] + "…" : s.Id)</td>
              <td style="padding: 0.625rem 1rem;">@(s.DeviceType ?? "∅")</td>
              <td style="padding: 0.625rem 1rem; color: var(--slate-400);">@(s.Browser ?? "∅") · @(s.Os ?? "∅")</td>
              <td style="padding: 0.625rem 1rem; text-align: right; color: white; font-weight: 600;">@s.PageCount</td>
              <td style="padding: 0.625rem 1rem; text-align: right; color: var(--slate-500);">@s.EventCount</td>
              <td style="padding: 0.625rem 1rem; font-family: ui-monospace, monospace;">@(s.UtmSource ?? "(direct)")</td>
              <td style="padding: 0.625rem 1rem;">
                @if (s.IsBot)
                {
                  <span style="display: inline-block; padding: 0.125rem 0.5rem; border-radius: 999px; background: rgba(245,158,11,0.15); color: #f59e0b; font-size: 0.625rem;">bot: @s.BotReason</span>
                }
                else if (s.Converted)
                {
                  <span style="display: inline-block; padding: 0.125rem 0.5rem; border-radius: 999px; background: rgba(59,130,246,0.15); color: #3b82f6; font-size: 0.625rem;">converted</span>
                }
                else
                {
                  <span style="display: inline-block; padding: 0.125rem 0.5rem; border-radius: 999px; background: rgba(16,185,129,0.1); color: #10b981; font-size: 0.625rem;">human</span>
                }
              </td>
            </tr>
          }
        </tbody>
      </table>
    }
  </div>

  <!-- Pagination -->
  @if (Model.TotalPages > 1)
  {
    <div style="display: flex; gap: 0.5rem; margin-top: 1.5rem; justify-content: center; font-size: 0.75rem;">
      @for (var p = Math.Max(1, Model.PageIndex - 3); p <= Math.Min(Model.TotalPages, Model.PageIndex + 3); p++)
      {
        var active = p == Model.PageIndex;
        <a href="?page=@p&device=@Model.Device&bot=@Model.Bot&converted=@Model.Converted&source=@Model.Source"
           style="padding: 0.375rem 0.75rem; border-radius: 0.25rem; text-decoration: none;
                  background: @(active ? "rgba(59,130,246,0.2)" : "rgba(255,255,255,0.03)");
                  color: @(active ? "white" : "var(--slate-400)");
                  border: 1px solid @(active ? "rgba(59,130,246,0.4)" : "rgba(255,255,255,0.05)");">
          @p
        </a>
      }
    </div>
  }
</div>
