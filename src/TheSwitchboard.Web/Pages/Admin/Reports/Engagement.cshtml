@page
@model TheSwitchboard.Web.Pages.Admin.Reports.EngagementModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Engagement";
    var maxBucket = Model.DurationBuckets.Count == 0 ? 1 : Math.Max(1, Model.DurationBuckets.Max(b => b.Count));
}

<div style="max-width: 1200px;">
  <h1 style="font-size: 1.5rem; font-weight: 700; color: white; margin-bottom: 0.25rem;">Engagement</h1>
  <p style="color: var(--slate-500); margin-bottom: 1.5rem;">Average time on site, pages per session, duration distribution, return-visit rate.</p>

  <div style="display: flex; gap: 0.5rem; margin-bottom: 1.5rem;">
    @foreach (var d in new[] { 7, 30, 90 })
    {
      var active = Model.WindowDays == d;
      <a href="?days=@d" style="padding: 0.375rem 0.75rem; border-radius: 0.375rem; font-size: 0.75rem; text-decoration: none;
         background: @(active ? "rgba(59,130,246,0.2)" : "rgba(255,255,255,0.03)");
         color: @(active ? "white" : "var(--slate-400)");
         border: 1px solid @(active ? "rgba(59,130,246,0.4)" : "rgba(255,255,255,0.05)");">@(d)d</a>
    }
  </div>

  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.25rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">Sessions</div>
      <div style="font-size: 1.75rem; font-weight: 700; color: white;">@Model.TotalSessions</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.25rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">Avg duration</div>
      <div style="font-size: 1.75rem; font-weight: 700; color: white;">@Math.Round(Model.AvgDurationSec, 1)s</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.25rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">Pages / session</div>
      <div style="font-size: 1.75rem; font-weight: 700; color: white;">@Math.Round(Model.AvgPagesPerSession, 2)</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.25rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">Returning visitors</div>
      <div style="font-size: 1.75rem; font-weight: 700; color: #10b981;">@Model.ReturnVisitorPct%</div>
    </div>
  </div>

  <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; overflow: hidden;">
    <div style="padding: 1rem 1.25rem; border-bottom: 1px solid rgba(255,255,255,0.05);">
      <h2 style="font-size: 0.875rem; font-weight: 600; color: white;">Session-duration distribution</h2>
    </div>
    <div style="padding: 1rem 1.25rem;">
      @foreach (var b in Model.DurationBuckets)
      {
        var width = Math.Round((double)b.Count / maxBucket * 100, 1);
        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem; font-size: 0.75rem;">
          <span style="color: var(--slate-500); width: 70px;">@b.Label</span>
          <div style="flex: 1; background: rgba(255,255,255,0.04); height: 14px; border-radius: 4px; overflow: hidden;">
            <div style="background: linear-gradient(90deg, #3b82f6, #60a5fa); height: 100%; width: @(width.ToString("0.#"))%;"></div>
          </div>
          <span style="color: white; width: 50px; text-align: right; font-weight: 600;">@b.Count</span>
        </div>
      }
    </div>
  </div>
</div>
