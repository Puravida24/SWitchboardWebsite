@page
@model TheSwitchboard.Web.Pages.Admin.Reports.Heatmaps.ClickModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Click heatmap";
    var showRage = Model.Filter != "normal" && Model.Filter != "dead";
    var showDead = Model.Filter != "normal" && Model.Filter != "rage";
    var showNormal = Model.Filter != "rage" && Model.Filter != "dead";
}

<div style="max-width: 1400px;">
  <h1 style="font-size: 1.5rem; font-weight: 700; color: white; margin-bottom: 0.25rem;">Click heatmap — @Model.Path</h1>
  <p style="color: var(--slate-500); margin-bottom: 1.5rem;">
    Each dot is a click, scaled to viewport width. Red = rage click (bursts of 3+ on same selector). Orange = dead click (no DOM change, no nav).
  </p>

  <form method="get" style="display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 1.5rem; align-items: center; font-size: 0.75rem;">
    <label style="color: var(--slate-500);">
      Page
      <select name="path" style="margin-left: 0.375rem; padding: 0.375rem 0.5rem; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.08); border-radius: 0.25rem; color: white;">
        @if (!Model.AvailablePaths.Contains(Model.Path))
        {
          <option value="@Model.Path" selected>@Model.Path</option>
        }
        @foreach (var p in Model.AvailablePaths)
        {
          <option value="@p" selected="@(p == Model.Path)">@p</option>
        }
      </select>
    </label>
    <label style="color: var(--slate-500);">
      Window
      <select name="days" style="margin-left: 0.375rem; padding: 0.375rem 0.5rem; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.08); border-radius: 0.25rem; color: white;">
        @foreach (var d in new[] { 1, 7, 30, 90 })
        {
          <option value="@d" selected="@(d == Model.WindowDays)">@(d == 1 ? "24h" : $"{d}d")</option>
        }
      </select>
    </label>
    <label style="color: var(--slate-500);">
      Filter
      <select name="filter" style="margin-left: 0.375rem; padding: 0.375rem 0.5rem; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.08); border-radius: 0.25rem; color: white;">
        <option value="" selected="@(string.IsNullOrEmpty(Model.Filter))">all clicks</option>
        <option value="rage" selected="@(Model.Filter == "rage")">rage only</option>
        <option value="dead" selected="@(Model.Filter == "dead")">dead only</option>
        <option value="normal" selected="@(Model.Filter == "normal")">normal only</option>
      </select>
    </label>
    <button type="submit" style="padding: 0.375rem 1rem; border-radius: 0.25rem; background: rgba(59,130,246,0.2); border: 1px solid rgba(59,130,246,0.4); color: white; cursor: pointer;">Apply</button>
    <span style="color: var(--slate-500); margin-left: auto;">
      @Model.Dots.Count dots &middot;
      <span style="color: #ef4444;">@Model.RageCount rage</span> &middot;
      <span style="color: #f59e0b;">@Model.DeadCount dead</span>
    </span>
  </form>

  <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; overflow: hidden;">
    <div style="padding: 1rem 1.25rem; border-bottom: 1px solid rgba(255,255,255,0.05); color: var(--slate-500); font-size: 0.75rem;">
      Coordinates projected onto the iframe below. Hover each dot to see its exact XY.
    </div>
    <div style="position: relative; width: 100%; background: #0a0a0a;">
      <iframe src="@Model.Path" style="width: 100%; height: 800px; border: 0; display: block;" sandbox="allow-same-origin" title="Live preview"></iframe>
      <div style="position: absolute; inset: 0; pointer-events: none;">
        @foreach (var d in Model.Dots)
        {
          if (d.ViewportW == 0) continue;
          if (d.IsRage && !showRage) continue;
          if (d.IsDead && !showDead) continue;
          if (!d.IsRage && !d.IsDead && !showNormal) continue;

          var pctX = Math.Clamp((double)d.X / d.ViewportW, 0.0, 1.0) * 100;
          var pctY = Math.Clamp((double)d.Y / Math.Max(d.ViewportH, 1), 0.0, 1.0) * 100;
          var color = d.IsRage ? "rgba(239,68,68,0.55)" : d.IsDead ? "rgba(245,158,11,0.55)" : "rgba(59,130,246,0.35)";
          var size = d.IsRage ? 14 : d.IsDead ? 12 : 8;
          <div title="@($"x={d.X} y={d.Y} vp={d.ViewportW}×{d.ViewportH}{(d.IsRage ? " rage" : "")}{(d.IsDead ? " dead" : "")}")"
               style="position: absolute; left: @(pctX.ToString("0.##"))%; top: @(pctY.ToString("0.##"))%; width: @(size)px; height: @(size)px; margin-left: -@(size/2)px; margin-top: -@(size/2)px; border-radius: 999px; background: @color;"></div>
        }
      </div>
    </div>
  </div>
</div>
