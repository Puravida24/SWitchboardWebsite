@page
@model TheSwitchboard.Web.Pages.Admin.Reports.DisclosuresModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Disclosure versions";
}

<div style="max-width: 1200px;">
  <h1 style="font-size: 1.5rem; font-weight: 700; color: white; margin-bottom: 0.25rem;">Disclosure versions</h1>
  <p style="color: var(--slate-500); margin-bottom: 1.5rem;">
    Every unique consent disclosure text observed on the site, identified by SHA-256 canonical hash.
    New versions auto-detect on first POST. Promote to <strong>registered</strong> after legal review.
  </p>

  @if (Model.Versions.Count == 0)
  {
    <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 2rem; color: var(--slate-500); font-size: 0.875rem;">
      No disclosure versions recorded yet. One will auto-create on the first form submission with consent text.
    </div>
  }
  else
  {
    @foreach (var v in Model.Versions)
    {
      var count = Model.CertCounts.TryGetValue(v.Id, out var n) ? n : 0;
      var statusColor = v.Status switch
      {
        "registered" => "#10b981",
        "retired" => "var(--slate-500)",
        _ => "#f59e0b"
      };
      <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.5rem; margin-bottom: 1rem;">
        <div style="display: flex; justify-content: space-between; align-items: start; gap: 1rem; margin-bottom: 0.75rem;">
          <div>
            <div style="display: flex; gap: 0.5rem; align-items: center;">
              <span style="font-size: 1.125rem; font-weight: 700; color: white;">@v.Version</span>
              <span style="display: inline-block; padding: 0.125rem 0.625rem; border-radius: 999px; background: rgba(255,255,255,0.04); color: @statusColor; font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600;">@v.Status</span>
              <span style="color: var(--slate-500); font-size: 0.75rem;">@count cert(s) issued</span>
            </div>
            <div style="color: var(--slate-500); font-size: 0.75rem; margin-top: 0.25rem;">
              Effective from @v.EffectiveFrom.ToString("yyyy-MM-dd HH:mm") UTC
              @if (v.EffectiveTo is DateTime t) { <text> · retired @t.ToString("yyyy-MM-dd")</text> }
              @if (!string.IsNullOrEmpty(v.CreatedBy)) { <text> · by @v.CreatedBy</text> }
            </div>
          </div>
          <div style="display: flex; gap: 0.375rem;">
            @if (v.Status == "auto-detected")
            {
              <form method="post" asp-page-handler="Register" asp-route-id="@v.Id" style="margin: 0;">
                @Html.AntiForgeryToken()
                <button type="submit" style="padding: 0.375rem 0.875rem; border-radius: 0.25rem; background: rgba(16,185,129,0.15); border: 1px solid rgba(16,185,129,0.4); color: #10b981; font-size: 0.75rem; font-weight: 600; cursor: pointer;">Register (legal approved)</button>
              </form>
            }
            @if (v.Status == "registered")
            {
              <form method="post" asp-page-handler="Retire" asp-route-id="@v.Id" style="margin: 0;">
                @Html.AntiForgeryToken()
                <button type="submit" style="padding: 0.375rem 0.875rem; border-radius: 0.25rem; background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.4); color: #ef4444; font-size: 0.75rem; font-weight: 600; cursor: pointer;">Retire</button>
              </form>
            }
          </div>
        </div>
        <div style="padding: 1rem; background: rgba(0,0,0,0.25); border-radius: 0.375rem; color: var(--slate-300); font-size: 0.8125rem; line-height: 1.5;">@v.FullText</div>
        <div style="color: var(--slate-600); font-size: 0.625rem; margin-top: 0.5rem; font-family: ui-monospace, monospace;">hash: @v.TextHash</div>
      </div>
    }
  }
</div>
