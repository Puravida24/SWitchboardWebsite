@page
@model TheSwitchboard.Web.Pages.Admin.Reports.SegmentsModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Segments";
}

<div style="max-width: 1000px;">
  <h1 style="font-size: 1.5rem; font-weight: 700; color: white; margin-bottom: 0.25rem;">Segments</h1>
  <p style="color: var(--slate-500); margin-bottom: 1.5rem;">Saved filter queries you can apply to any report. Filter JSON keys: <code>device</code>, <code>source</code>, <code>browser</code>, <code>converted</code>, <code>bot</code>.</p>

  <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.25rem; margin-bottom: 1.5rem;">
    <h2 style="font-size: 0.875rem; font-weight: 600; color: white; margin-bottom: 0.75rem;">New segment</h2>
    <form method="post" asp-page-handler="Create" style="display: flex; flex-direction: column; gap: 0.5rem; font-size: 0.75rem;">
      @Html.AntiForgeryToken()
      <input asp-for="NewName" placeholder="Segment name" required style="padding: 0.5rem 0.75rem; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.08); border-radius: 0.25rem; color: white;" />
      <textarea asp-for="NewFilter" rows="3" placeholder='{"device":"desktop","source":"linkedin"}' style="padding: 0.5rem 0.75rem; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.08); border-radius: 0.25rem; color: white; font-family: ui-monospace, monospace;"></textarea>
      <button type="submit" style="align-self: start; padding: 0.375rem 1rem; border-radius: 0.25rem; background: rgba(16,185,129,0.15); border: 1px solid rgba(16,185,129,0.4); color: #6ee7b7; cursor: pointer;">Save segment</button>
    </form>
  </div>

  <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; overflow: hidden;">
    @if (Model.Segments.Count == 0)
    {
      <div style="padding: 1.5rem; color: var(--slate-500); font-size: 0.875rem;">No saved segments yet.</div>
    }
    else
    {
      @foreach (var s in Model.Segments)
      {
        <div style="padding: 1rem 1.25rem; border-top: 1px solid rgba(255,255,255,0.04); display: flex; gap: 1rem; align-items: center;">
          <div style="flex: 1;">
            <div style="color: white; font-weight: 600;">@s.Name</div>
            <div style="color: var(--slate-500); font-family: ui-monospace, monospace; font-size: 0.75rem; margin-top: 0.25rem;">@s.Filter</div>
            <div style="color: var(--slate-600); font-size: 0.625rem; margin-top: 0.25rem;">created @s.CreatedAt.ToString("MMM d") @(string.IsNullOrEmpty(s.CreatedBy) ? "" : $"by {s.CreatedBy}")</div>
          </div>
          <form method="post" asp-page-handler="Delete" asp-route-id="@s.Id" style="margin: 0;">
            @Html.AntiForgeryToken()
            <button type="submit" style="padding: 0.375rem 0.875rem; border-radius: 0.25rem; background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.4); color: #fecaca; font-size: 0.75rem; cursor: pointer;">Delete</button>
          </form>
        </div>
      }
    }
  </div>
</div>
