@page
@model TheSwitchboard.Web.Pages.Admin.Reports.Visitors.ProfileModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Visitor profile";
    var p = Model.Profile;
}

<div style="max-width: 1200px;">
  <a href="/Admin/Reports/Visitors" style="font-size: 0.75rem; color: var(--slate-500); text-decoration: none;">← All visitors</a>
  <h1 style="font-size: 1.5rem; font-weight: 700; color: white; margin-top: 0.5rem; margin-bottom: 0.25rem;">Visitor profile</h1>
  <p style="font-family: ui-monospace, monospace; color: var(--slate-500); margin-bottom: 1.5rem;">@p!.Visitor.Id</p>

  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.375rem;">Sessions</div>
      <div style="font-size: 1.5rem; font-weight: 700; color: white;">@p.Sessions.Count</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.375rem;">Pageviews</div>
      <div style="font-size: 1.5rem; font-weight: 700; color: white;">@p.PageViewCount</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.375rem;">Submissions</div>
      <div style="font-size: 1.5rem; font-weight: 700; color: #10b981;">@p.SubmissionCount</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.375rem;">JS errors</div>
      <div style="font-size: 1.5rem; font-weight: 700; color: @(p.ErrorCount > 0 ? "#ef4444" : "white");">@p.ErrorCount</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.375rem;">First seen</div>
      <div style="font-size: 0.875rem; color: white;">@p.Visitor.FirstSeen.ToString("MMM d yyyy")</div>
    </div>
  </div>

  <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; overflow: hidden;">
    <div style="padding: 1rem 1.25rem; border-bottom: 1px solid rgba(255,255,255,0.05);">
      <h2 style="font-size: 0.875rem; font-weight: 600; color: white;">All sessions</h2>
    </div>
    @if (p.Sessions.Count == 0)
    {
      <div style="padding: 1.5rem; color: var(--slate-500); font-size: 0.875rem;">No sessions recorded yet.</div>
    }
    else
    {
      <table style="width: 100%; border-collapse: collapse; font-size: 0.75rem;">
        <thead>
          <tr style="color: var(--slate-500); text-transform: uppercase; font-size: 0.625rem; letter-spacing: 0.1em;">
            <th style="text-align: left; padding: 0.625rem 1rem;">Started</th>
            <th style="text-align: left; padding: 0.625rem 1rem;">Landing</th>
            <th style="text-align: left; padding: 0.625rem 1rem;">Device</th>
            <th style="text-align: right; padding: 0.625rem 1rem;">PVs</th>
            <th style="text-align: right; padding: 0.625rem 1rem;">Dwell</th>
            <th style="text-align: left; padding: 0.625rem 1rem;">Source</th>
            <th style="text-align: left; padding: 0.625rem 1rem;"></th>
          </tr>
        </thead>
        <tbody>
          @foreach (var s in p.Sessions)
          {
            <tr style="border-top: 1px solid rgba(255,255,255,0.04); color: var(--slate-300);">
              <td style="padding: 0.5rem 1rem; color: var(--slate-500);">@s.StartedAt.ToString("MMM d HH:mm")</td>
              <td style="padding: 0.5rem 1rem; font-family: ui-monospace, monospace;">@(s.LandingPath ?? "/")</td>
              <td style="padding: 0.5rem 1rem;">@(s.DeviceType ?? "?") · @(s.Browser ?? "?")</td>
              <td style="padding: 0.5rem 1rem; text-align: right; color: white; font-weight: 600;">@s.PageCount</td>
              <td style="padding: 0.5rem 1rem; text-align: right; color: var(--slate-500);">@s.DurationSeconds s</td>
              <td style="padding: 0.5rem 1rem; color: var(--slate-400); font-family: ui-monospace, monospace;">@(s.UtmSource ?? "(direct)")</td>
              <td style="padding: 0.5rem 1rem;"><a href="/Admin/Reports/Sessions/Detail?id=@s.Id" style="color: #3b82f6; font-size: 0.75rem;">Session →</a></td>
            </tr>
          }
        </tbody>
      </table>
    }
  </div>
</div>
