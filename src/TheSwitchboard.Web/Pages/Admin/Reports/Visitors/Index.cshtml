@page "/Admin/Reports/Visitors"
@model TheSwitchboard.Web.Pages.Admin.Reports.Visitors.IndexModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Visitors";
}

<div style="max-width: 1400px;">
  <h1 style="font-size: 1.5rem; font-weight: 700; color: white; margin-bottom: 0.25rem;">Visitors</h1>
  <p style="color: var(--slate-500); margin-bottom: 1.5rem;">Distinct <code>sw_vid</code>. Click a row to see every session + event for that visitor.</p>

  <div style="display: flex; gap: 0.5rem; margin-bottom: 1.5rem;">
    @foreach (var d in new[] { 7, 30, 90, 365 })
    {
      var active = Model.WindowDays == d;
      <a href="?days=@d" style="padding: 0.375rem 0.75rem; border-radius: 0.375rem; font-size: 0.75rem; text-decoration: none;
         background: @(active ? "rgba(59,130,246,0.2)" : "rgba(255,255,255,0.03)");
         color: @(active ? "white" : "var(--slate-400)");
         border: 1px solid @(active ? "rgba(59,130,246,0.4)" : "rgba(255,255,255,0.05)");">@(d == 365 ? "1y" : $"{d}d")</a>
    }
    <span style="margin-left: auto; color: var(--slate-500); font-size: 0.75rem; align-self: center;">@Model.Total total</span>
  </div>

  <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; overflow: hidden;">
    @if (Model.Rows.Count == 0)
    {
      <div style="padding: 2rem; color: var(--slate-500); font-size: 0.875rem;">No visitors yet in this window.</div>
    }
    else
    {
      <table style="width: 100%; border-collapse: collapse; font-size: 0.8125rem;">
        <thead>
          <tr style="color: var(--slate-500); text-transform: uppercase; font-size: 0.625rem; letter-spacing: 0.1em;">
            <th style="text-align: left; padding: 0.625rem 1rem;">Visitor</th>
            <th style="text-align: left; padding: 0.625rem 1rem;">First seen</th>
            <th style="text-align: left; padding: 0.625rem 1rem;">Last seen</th>
            <th style="text-align: right; padding: 0.625rem 1rem;">Sessions</th>
            <th style="text-align: left; padding: 0.625rem 1rem;">Converted</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var v in Model.Rows)
          {
            <tr style="border-top: 1px solid rgba(255,255,255,0.04); color: var(--slate-300);">
              <td style="padding: 0.625rem 1rem; font-family: ui-monospace, monospace;">
                <a href="/Admin/Reports/Visitors/Profile?id=@v.Id" style="color: #3b82f6; text-decoration: none;">@(v.Id.Length > 20 ? v.Id[..20] + "…" : v.Id)</a>
              </td>
              <td style="padding: 0.625rem 1rem; color: var(--slate-500);">@v.FirstSeen.ToString("MMM d HH:mm")</td>
              <td style="padding: 0.625rem 1rem; color: var(--slate-500);">@v.LastSeen.ToString("MMM d HH:mm")</td>
              <td style="padding: 0.625rem 1rem; text-align: right; font-weight: 600; color: white;">@v.SessionCount</td>
              <td style="padding: 0.625rem 1rem;">
                @if (v.Converted)
                {
                  <span style="display: inline-block; padding: 0.125rem 0.5rem; border-radius: 999px; background: rgba(59,130,246,0.15); color: #3b82f6; font-size: 0.625rem;">yes</span>
                }
              </td>
            </tr>
          }
        </tbody>
      </table>
    }
  </div>
</div>
