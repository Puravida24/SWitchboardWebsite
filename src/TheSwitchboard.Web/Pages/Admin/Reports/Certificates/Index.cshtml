@page
@model TheSwitchboard.Web.Pages.Admin.Reports.Certificates.IndexModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Consent certificates";
}

<div style="max-width: 1400px;">
  <h1 style="font-size: 1.5rem; font-weight: 700; color: white; margin-bottom: 0.25rem;">Consent certificates</h1>
  <p style="color: var(--slate-500); margin-bottom: 1.5rem;">
    Every issued TCPA consent record. Click a cert to see the full proof.
  </p>

  <form method="get" style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1.5rem; font-size: 0.75rem; align-items: center;">
    <label style="color: var(--slate-500);">
      Status
      <select name="status" style="margin-left: 0.375rem; padding: 0.375rem 0.5rem; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.08); border-radius: 0.25rem; color: white;">
        <option value="" selected="@(string.IsNullOrEmpty(Model.Status))">all</option>
        <option value="human" selected="@(Model.Status == "human")">humans only</option>
        <option value="bot" selected="@(Model.Status == "bot")">suspicious bots</option>
        <option value="expired" selected="@(Model.Status == "expired")">expired</option>
      </select>
    </label>
    @foreach (var d in new[] { 7, 30, 90, 365 })
    {
      var active = Model.WindowDays == d;
      <a href="?days=@d&status=@Model.Status" style="padding: 0.375rem 0.75rem; border-radius: 0.25rem; text-decoration: none;
         background: @(active ? "rgba(59,130,246,0.2)" : "rgba(255,255,255,0.03)");
         color: @(active ? "white" : "var(--slate-400)");
         border: 1px solid @(active ? "rgba(59,130,246,0.4)" : "rgba(255,255,255,0.05)");">
        @(d == 365 ? "1y" : $"{d}d")
      </a>
    }
  </form>

  <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; overflow: hidden;">
    @if (Model.Rows.Count == 0)
    {
      <div style="padding: 2rem; color: var(--slate-500); font-size: 0.875rem;">No certificates in this window.</div>
    }
    else
    {
      <table style="width: 100%; border-collapse: collapse; font-size: 0.75rem;">
        <thead>
          <tr style="color: var(--slate-500); text-transform: uppercase; font-size: 0.625rem; letter-spacing: 0.1em;">
            <th style="text-align: left; padding: 0.625rem 1rem;">Created</th>
            <th style="text-align: left; padding: 0.625rem 1rem;">Certificate</th>
            <th style="text-align: left; padding: 0.625rem 1rem;">Session</th>
            <th style="text-align: right; padding: 0.625rem 1rem;">Contrast</th>
            <th style="text-align: left; padding: 0.625rem 1rem;">Status</th>
            <th style="text-align: left; padding: 0.625rem 1rem;">Expires</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var c in Model.Rows)
          {
            var expired = c.ExpiresAt < DateTime.UtcNow;
            <tr style="border-top: 1px solid rgba(255,255,255,0.04); color: var(--slate-300);">
              <td style="padding: 0.625rem 1rem; color: var(--slate-400);">@c.CreatedAt.ToString("MMM d HH:mm")</td>
              <td style="padding: 0.625rem 1rem; font-family: ui-monospace, monospace;">
                <a href="/Admin/Reports/Certificates/Detail?id=@c.CertificateId" style="color: #3b82f6; text-decoration: none;">@(c.CertificateId.Length > 24 ? c.CertificateId[..24] + "…" : c.CertificateId)</a>
              </td>
              <td style="padding: 0.625rem 1rem; font-family: ui-monospace, monospace; color: var(--slate-500);">@(c.SessionId ?? "∅")</td>
              <td style="padding: 0.625rem 1rem; text-align: right;">@(c.DisclosureContrastRatio?.ToString("0.##") ?? "—")</td>
              <td style="padding: 0.625rem 1rem;">
                @if (c.IsSuspiciousBot)
                {
                  <span style="display: inline-block; padding: 0.125rem 0.5rem; border-radius: 999px; background: rgba(245,158,11,0.15); color: #f59e0b; font-size: 0.625rem;">bot</span>
                }
                else if (expired)
                {
                  <span style="display: inline-block; padding: 0.125rem 0.5rem; border-radius: 999px; background: rgba(239,68,68,0.15); color: #ef4444; font-size: 0.625rem;">expired</span>
                }
                else
                {
                  <span style="display: inline-block; padding: 0.125rem 0.5rem; border-radius: 999px; background: rgba(16,185,129,0.1); color: #10b981; font-size: 0.625rem;">valid</span>
                }
              </td>
              <td style="padding: 0.625rem 1rem; color: var(--slate-500);">@c.ExpiresAt.ToString("yyyy-MM-dd")</td>
            </tr>
          }
        </tbody>
      </table>
    }
  </div>
</div>
