@page
@model TheSwitchboard.Web.Pages.Admin.Reports.Certificates.DetailModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Certificate";
    var c = Model.Cert;
    var expired = Model.IsExpired;
    var contrastBucket = c?.DisclosureContrastRatio switch
    {
        null => "n/a",
        >= 7.0 => "AAA",
        >= 4.5 => "AA",
        _ => "fail"
    };
}

<div style="max-width: 1000px;">
  <a href="/Admin/Reports/Certificates" style="font-size: 0.75rem; color: var(--slate-500); text-decoration: none;">← All certificates</a>
  <h1 style="font-size: 1.5rem; font-weight: 700; color: white; margin-top: 0.5rem; margin-bottom: 0.25rem;">Consent certificate</h1>
  <p style="font-family: ui-monospace, monospace; color: var(--slate-500); margin-bottom: 1.5rem; word-break: break-all;">@c!.CertificateId</p>

  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.375rem;">Created</div>
      <div style="color: white; font-size: 0.875rem;">@c.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.375rem;">Expires</div>
      <div style="color: @(expired ? "#ef4444" : "white"); font-size: 0.875rem;">@c.ExpiresAt.ToString("yyyy-MM-dd") @(expired ? "(EXPIRED)" : "")</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.375rem;">WCAG</div>
      <div style="color: white; font-size: 0.875rem;">@contrastBucket · @(c.DisclosureContrastRatio?.ToString("0.##") ?? "—"):1</div>
    </div>
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1rem;">
      <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.375rem;">Bot</div>
      <div style="color: @(c.IsSuspiciousBot ? "#f59e0b" : "#10b981"); font-size: 0.875rem;">@(c.IsSuspiciousBot ? "suspicious" : "human")</div>
    </div>
  </div>

  <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.5rem; margin-bottom: 1rem;">
    <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">Disclosure shown to user</div>
    <div style="padding: 1rem; background: @(c.DisclosureBackgroundColor ?? "rgba(255,255,255,0.04)"); color: @(c.DisclosureColor ?? "white"); border-radius: 0.375rem; font-size: @(c.DisclosureFontSize ?? "0.875rem");">
      @c.DisclosureText
    </div>
    <div style="color: var(--slate-600); font-size: 0.75rem; margin-top: 0.5rem; font-family: ui-monospace, monospace;">hash: @c.DisclosureTextHash</div>
  </div>

  <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.5rem; margin-bottom: 1rem;">
    <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">Behavioral signals</div>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 0.75rem; font-size: 0.75rem; color: var(--slate-300);">
      <div><div style="color: var(--slate-500); font-size: 0.625rem;">Keystrokes/min</div>@(c.KeystrokesPerMinute ?? 0)</div>
      <div><div style="color: var(--slate-500); font-size: 0.625rem;">Fields interacted</div>@(c.FormFieldsInteracted ?? 0)</div>
      <div><div style="color: var(--slate-500); font-size: 0.625rem;">Mouse px</div>@(c.MouseDistancePx ?? 0)</div>
      <div><div style="color: var(--slate-500); font-size: 0.625rem;">Scroll depth</div>@(c.ScrollDepthPercent ?? 0)%</div>
      <div><div style="color: var(--slate-500); font-size: 0.625rem;">Time on page</div>@(c.TimeOnPageSeconds ?? 0)s</div>
      <div><div style="color: var(--slate-500); font-size: 0.625rem;">Click coords</div>(@(c.ClickX ?? 0), @(c.ClickY ?? 0))</div>
    </div>
  </div>

  <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.5rem; padding: 1.5rem; margin-bottom: 1rem;">
    <div style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--slate-500); margin-bottom: 0.5rem;">Environment</div>
    <div style="color: white; font-size: 0.875rem;">@(c.BrowserName ?? "?") · @(c.OsName ?? "?") · @(c.ScreenResolution ?? "?") · @(c.ViewportW ?? 0)×@(c.ViewportH ?? 0)</div>
    <div style="color: var(--slate-500); font-size: 0.75rem; margin-top: 0.375rem; font-family: ui-monospace, monospace;">@c.UserAgent</div>
    <div style="color: var(--slate-500); font-size: 0.75rem; margin-top: 0.375rem;">IP: @(c.IpAddress ?? "∅") · Session: @(c.SessionId ?? "∅")</div>
    @if (c.FormSubmissionId is int fid)
    {
      <div style="margin-top: 0.75rem; font-size: 0.75rem;"><a href="/Admin/Submissions/Detail?id=@fid" style="color: #3b82f6;">Linked form submission #@fid →</a></div>
    }
  </div>

  <div style="display: flex; gap: 0.75rem;">
    <a href="/verify/@c.CertificateId" target="_blank" rel="noopener" style="padding: 0.625rem 1rem; border-radius: 0.375rem; background: rgba(59,130,246,0.2); border: 1px solid rgba(59,130,246,0.4); color: white; text-decoration: none; font-size: 0.875rem;">Open public /verify page ↗</a>
    @if (c.SessionId is not null)
    {
      <a href="/Admin/Reports/Sessions/Detail?id=@c.SessionId" style="padding: 0.625rem 1rem; border-radius: 0.375rem; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); color: var(--slate-300); text-decoration: none; font-size: 0.875rem;">Session replay →</a>
    }
  </div>
</div>
