root = true

# All files
[*]
indent_style = space
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# C# / Razor
[*.{cs,cshtml,razor}]
indent_size = 4

# C# code-style rules (enforced in build via EnforceCodeStyleInBuild at
# project-level; this file is advisory for IDEs + dotnet-format).
[*.cs]
# Prefer `var` only when the type is apparent on the RHS — keeps explicit
# types for model boundaries where the read matters.
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

# File-scoped namespaces — single-namespace-per-file is already the norm here.
csharp_style_namespace_declarations = file_scoped:suggestion

# Nullable context is per-project (Nullable=enable in csproj); this is a
# no-op reminder for IDEs that collapse the nullable annotation context.
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion

# Nudge developers away from public mutable fields — preferred record/init.
dotnet_style_readonly_field = true:suggestion

# Tests project — tolerate looser rules (e.g. unused async, magic numbers).
[src/TheSwitchboard.Web.Tests/**.cs]
# Empty override — inherits [*.cs]; this section exists so future
# test-only relaxations have an obvious home.

# Razor Pages layout
[*.cshtml]
indent_size = 2

# JSON / YAML / Markdown
[*.{json,yml,yaml}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false  # Markdown uses trailing spaces for line breaks.

# JS / CSS under wwwroot
[*.{js,css}]
indent_size = 2
